---
// ──────────────────────────────────────────────────────────────
// OdeLayout — isolated layout for the /OdE microsite.
//
// Deliberately does NOT use the host site's Header/Footer/Navigation,
// so /OdE inherits none of Matteo's personal navigation. Isolation:
//   1. own header/footer (below) — no link from the host nav
//   2. <meta name="robots" content="noindex, nofollow">
//   3. excluded from sitemap (see astro.config.mjs filter)
// Reachable only via direct URL.
// ──────────────────────────────────────────────────────────────
import '../styles/ode-theme.css';
import { odeUI, odeRoutes, type OdeLang, type OdeRouteKey } from '../i18n/ode';

interface Props {
  title: string;
  description?: string;
  lang?: OdeLang;
  /** Which nav item is the current page (for active state). */
  active?: OdeRouteKey;
}

const { title, description = '', lang = 'it', active } = Astro.props;
const t = odeUI[lang];
const r = odeRoutes[lang];

// Language switch: same page, other language.
const other: OdeLang = lang === 'it' ? 'en' : 'it';
const otherHome = odeRoutes[other].home;

const navItems: { key: OdeRouteKey; label: string; href: string }[] = [
  { key: 'amsa', label: t.nav.amsa, href: r.amsa },
  { key: 'mercato', label: t.nav.mercato, href: r.mercato },
  { key: 'normativa', label: t.nav.normativa, href: r.normativa },
  { key: 'visione', label: t.nav.visione, href: r.visione },
  { key: 'investitori', label: t.nav.investitori, href: r.investitori },
];
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <!-- Isolation: keep the microsite out of search indexes -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OdE brand typeface: Roboto + Roboto Mono (OdE_Brand_System) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="ode">
    <header class="ode-header">
      <a href={r.home} class="ode-brand" aria-label={t.brand}>
        <span class="ode-brand-name">{t.brand}</span>
        <span class="ode-brand-tag">{t.tagline}</span>
      </a>

      <nav class="ode-nav" aria-label="OdE navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={['ode-nav-link', active === item.key && 'is-active']}
            aria-current={active === item.key ? 'page' : undefined}
          >{item.label}</a>
        ))}
        <a href={otherHome} class="ode-lang">{other.toUpperCase()}</a>
      </nav>
    </header>

    <main class="ode-main">
      <slot />
    </main>

    <footer class="ode-footer">
      <span>© {new Date().getFullYear()} {t.brand}</span>
      <nav class="ode-foot-links" aria-label="OdE utility">
        <a href={r.glossario}>{t.footer.glossario}</a>
        <a href={r.live}>{t.footer.live}</a>
      </nav>
      <span class="ode-sim-badge">{t.simBadge}</span>
    </footer>

    <style>
      .ode-header {
        max-width: var(--ode-maxw);
        margin: 0 auto;
        padding: 1.5rem 1.5rem;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        border-bottom: 1px solid var(--ode-rule);
      }
      .ode-brand { display: flex; flex-direction: column; text-decoration: none; }
      .ode-brand-name { font-weight: 500; color: var(--ode-ink); letter-spacing: 0.01em; }
      .ode-brand-tag {
        font-family: var(--ode-font-mono);
        font-size: 0.7rem;
        color: var(--ode-muted);
        letter-spacing: 0.02em;
      }
      .ode-nav { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
      .ode-nav-link {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--ode-muted);
        text-decoration: none;
        transition: color 160ms ease;
      }
      .ode-nav-link:hover { color: var(--ode-ink); }
      .ode-nav-link.is-active { color: var(--ode-accent); font-weight: 600; }
      .ode-lang {
        font-size: 0.75rem;
        font-family: var(--ode-font-mono);
        color: var(--ode-muted);
        text-decoration: none;
        border: 1px solid var(--ode-rule);
        border-radius: var(--ode-radius-sm);
        padding: 0.15rem 0.45rem;
      }
      .ode-main { max-width: var(--ode-maxw); margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
      .ode-footer {
        max-width: var(--ode-maxw);
        margin: 0 auto;
        padding: 2rem 1.5rem;
        border-top: 1px solid var(--ode-rule);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.75rem;
        color: var(--ode-muted);
        flex-wrap: wrap;
      }
      .ode-foot-links { display: flex; gap: 1rem; }
      .ode-foot-links a {
        color: var(--ode-muted);
        text-decoration: none;
        transition: color 160ms ease;
      }
      .ode-foot-links a:hover { color: var(--ode-ink); }
    </style>
  </body>
</html>
