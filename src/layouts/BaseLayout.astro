---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'it';
  /** Optional absolute or root-relative OG image (1200×630). Omitted if unset. */
  ogImage?: string;
}

const {
  title,
  description = 'Matteo Martignoni — Brand strategist. Workshop of brands.',
  lang = 'en',
  ogImage,
} = Astro.props;

// Canonical + language alternates, derived from the current path.
// EN lives at the root, IT under /it/ (mirrors Header.astro).
const path = Astro.url.pathname;
const enPath = path.startsWith('/it') ? path.replace(/^\/it/, '') || '/' : path;
const itPath = path.startsWith('/it') ? path : '/it' + (path === '/' ? '/' : path);

const canonical = new URL(path, Astro.site).href;
const enHref = new URL(enPath, Astro.site).href;
const itHref = new URL(itPath, Astro.site).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const ogLocale = lang === 'it' ? 'it_IT' : 'en_US';
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Canonical + bilingual alternates (helps Google serve the right language) -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="it" href={itHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph (link previews on LinkedIn, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Matteo Martignoni" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter / X card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-warm-50 text-ink-900">

    <Header lang={lang} />

    <!--
      full-bleed slot: renders OUTSIDE the padded <main>.
      Direct child of <body> — no padding, no max-width, no overflow.
      Used exclusively for the homepage hero section.
      All other pages use the default <slot /> inside <main>.
    -->
    <slot name="full-bleed" />

    <main class="flex-1 px-8 md:px-12">
      <slot />
    </main>

    <Footer lang={lang} />

  </body>
</html>
