---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import CompetencyAccordion from '../components/CompetencyAccordion.astro';

// Load all EN competencies, sorted by order field (01 through 06)
const allCompetencies = await getCollection('competencies');
const competencies = allCompetencies
  .filter(item => item.data.lang === 'en')
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Think — Matteo Martignoni"
  description="Six areas of practice in brand development: international expansion, new categories, licensing, retail, marketing, brand repositioning."
  lang="en"
>
  <SectionHero
    number="01"
    tagline="Areas of practice"
    title="Six things I know how to do."
    intro="Twenty-five years distilled into six interrelated practices. They work as lenses for reading a brand problem. Most projects touch three or four of them at once."
  />

  <section class="max-w-3xl mt-12 md:mt-16">

    {competencies.map((item, index) => (
      <CompetencyAccordion
        number={item.data.number}
        title={item.data.title}
        description={item.data.description}
        examples={item.data.examples}
        isFirst={false}
      />
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
