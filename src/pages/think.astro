---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import ThinkPractices from '../components/ThinkPractices.astro';
import { thinkHero } from '../data/think';

const hero = thinkHero.en;
---
<BaseLayout
  title="Brand Strategy & Repositioning — Matteo Martignoni"
  description="Brand work end to end: international development, new categories, licensing, retail strategy, marketing, brand repositioning, events."
  lang="en"
>
  <SectionHero
    number="01"
    tagline={hero.tagline}
    title={hero.title}
    intro={hero.lead}
  />

  <section class="max-w-3xl">
    <p class="text-ink-700 leading-relaxed">{hero.body}</p>

    <div class="mt-10 md:mt-14">
      <ThinkPractices lang="en" />
    </div>
  </section>
</BaseLayout>
