---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<BaseLayout
  title="Think — Matteo Martignoni"
  description="Six areas of practice in brand development: international expansion, new categories, licensing, retail, marketing, brand repositioning."
  lang="en"
>
  <SectionHero
    number="01"
    tagline="Areas of practice"
    title="Six things I know how to do."
    intro="Twenty-five years distilled into six interrelated practices. They work as lenses for reading a brand problem. Most projects touch three or four of them at once."
  />

  <section class="max-w-3xl mt-16 md:mt-20">
    <p class="text-xs uppercase tracking-widest text-ink-500/70 mb-2">
      Coming next
    </p>
    <p class="text-ink-500 leading-relaxed">
      The six practices, each with a description and a couple of project examples. Building in the next iteration.
    </p>
  </section>

</BaseLayout>
