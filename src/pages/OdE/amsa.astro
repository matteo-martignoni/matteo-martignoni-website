---
import OdeLayout from '../../layouts/OdeLayout.astro';
import Section from '../../components/ode/Section.astro';
import ControlLoop from '../../components/ode/ControlLoop.astro';
import PassportSections from '../../components/ode/PassportSections.astro';
import StatCard from '../../components/ode/StatCard.astro';
import DataTag from '../../components/ode/DataTag.astro';

const lang = 'it' as const;
const title = 'AMSA — Officina degli Estratti';
const description =
  "AMSA v3, l'agente spettroscopico multimodale guidato dall'AI: il dato causale provenienza verso stabilità, acquisizione governata, Passaporto Lipidico Digitale e posizionamento accanto al metodo accreditato.";

const verbs = ['Acquisisce', 'Interpreta', 'Predice', 'Spiega', 'Suggerisce'];

const problems = [
  'Variano per specie, alimentazione, rendering, età del materiale e stoccaggio.',
  'Ossidano facilmente: odore, irrancidimento, instabilità.',
  'Hanno componenti spettralmente sovrapposti (trigliceridi, acidi grassi liberi, cere, steroli, aldeidi, idroperossidi).',
  'Essendo prevalentemente sature, danno segnali di insaturazione deboli e una fluorescenza che disturba la misura.',
  'Richiedono analisi esterne costose (GC-FID, GC-MS, NMR, valore di perossidi, p-anisidina).',
];

// Posizionamento accanto al laboratorio accreditato (V3, cap. 11).
const roles = [
  { k: 'Triage e pre-screen', d: 'AMSA misura ogni lotto in ingresso e decide quali richiedono il panel accreditato completo e quali passano con il passaporto: meno volume e costo dei test di riferimento, a falsi negativi controllati.' },
  { k: 'Strato di provenienza', d: 'Il passaporto porta la provenienza verificata e la spiegazione interpretabile, informazione che il laboratorio accreditato di norma non fornisce.' },
  { k: 'Generazione di verità a terra', d: 'I test accreditati che il cliente comunque esegue diventano ground truth: addestrano il modello causale e nel tempo riducono il numero di test necessari.' },
];

const passport = [
  { n: '01', title: 'Identità', fields: 'sample_id, batch_id, origine, fornitore, rendering, process_history, cosmetic_grade_status' },
  { n: '02', title: 'Spectral fingerprint', fields: 'NIR raw/preprocessed, Raman raw/corrected, acquisition_temperature, quality_score, OOD_score' },
  { n: '03', title: 'Profilo acidi grassi', fields: 'saturi / mono / poli, lunghezza catena, omega (opz.), GC-FID confidence' },
  { n: '04', title: 'Ossidazione e stabilità', groups: [
    { label: 'Misurato', kind: 'fonte', fields: 'PV, p-anisidina, TBARS, TOTOX = 2·PV + AnV, acid value, OSI / induction time' },
    { label: 'Predetto', kind: 'stima', fields: 'Oxidative Risk Score, shelf-life' },
  ] },
  { n: '05', title: 'Fisico e formulativo', groups: [
    { fields: 'DSC, melting_range, colore, odor_score' },
    { label: 'Predetto', kind: 'stima', fields: 'crystallinity_proxy, viscosità (da spettro)' },
  ] },
  { n: '06', title: 'Biomarcatori', fields: 'unsaturation_index, CH₂/CH₃, carbonyl_index, aldeidi, idroperossidi, cere, steroli' },
  { n: '07', title: 'Raccomandazione processo', fields: 'accetta / purifica / deodora, adsorbente, blend_with, external_test_required' },
  { n: '08', title: 'Explainability', fields: 'top_spectral_regions, interpretazione chimica, confidence (copertura garantita), test confermativi' },
  { n: '09', title: 'Governance', fields: 'model_version, calibration_version, operator, timestamp, data_hash' },
];
---
<OdeLayout title={title} description={description} lang={lang} active="amsa">
  <header class="hero">
    <p class="ode-eyebrow">Pilastro 01 · La tecnologia</p>
    <h1>AMSA</h1>
    <p class="lede">
      AMSA è l'<strong>AI-driven Multimodal Spectroscopic Agent</strong>: un agente operativo che per
      ogni lotto acquisisce, interpreta, predice, spiega e suggerisce il processo, e costruisce un
      Passaporto Lipidico Digitale. Il cuore della versione 3 è il dato che lega la provenienza
      verificata a monte alla stabilità del grasso a valle: un dato causale che cresce a ogni lotto.
    </p>
    <div class="verbs">
      {verbs.map((v) => <span class="verb">{v}</span>)}
    </div>
  </header>

  <Section n="1" title="Il problema: matrici lipidiche difficili">
    <p>
      Le matrici lipidiche animali (sego bovino, grasso suino, lanolina, sebo, frazioni cerose e
      trigliceridiche) sono chimicamente ricche ma industrialmente difficili da standardizzare.
    </p>
    <ul class="problems">
      {problems.map((p) => <li>{p}</li>)}
    </ul>
    <p class="quote">
      La domanda ricorrente del cliente cosmetico: "questo ingrediente è stabile, non irrancidisce,
      non sviluppa odore, ha texture riproducibile, posso usarlo in una formula leave-on?"
    </p>
  </Section>

  <Section n="2" title="Il dato causale: provenienza verso stabilità">
    <p>
      Il valore di AMSA si concentra qui. Per ogni lotto AMSA costruisce una <strong>tripla appaiata</strong>:
      i metadati di provenienza a monte, il fingerprint spettrale, e l'esito di stabilità misurato come
      verità a terra. La libreria spettrale diventa una base di evidenza causale, capace di rispondere
      alla domanda che conta: date queste condizioni di origine, come si comporta questo grasso nel tempo?
    </p>

    <figure class="diagram">
      <svg viewBox="0 0 640 210" role="img" aria-label="Ciclo del dato causale: provenienza e spettro verso esito misurato e passaporto">
        <!-- provenienza (input · pesca) -->
        <rect x="12" y="28" width="158" height="54" rx="8" fill="#f6cbb3" stroke="#d9a07f"/>
        <text x="91" y="50" text-anchor="middle" font-family="Roboto" font-weight="500" font-size="11" fill="#8a472a">Provenienza</text>
        <text x="91" y="66" text-anchor="middle" font-family="Roboto" font-size="9" fill="#8a472a">dieta · stagione · rendering</text>
        <!-- spettro (processo · grigio-blu) -->
        <rect x="12" y="110" width="158" height="54" rx="8" fill="#c6cdd9" stroke="#9aa6ba"/>
        <text x="91" y="132" text-anchor="middle" font-family="Roboto" font-weight="500" font-size="11" fill="#33414c">Spettro</text>
        <text x="91" y="148" text-anchor="middle" font-family="Roboto" font-size="9" fill="#33414c">NIR + Raman di lotto</text>
        <!-- core: dato causale (esito · bianco + bordo verde) -->
        <rect x="246" y="68" width="172" height="66" rx="10" fill="#ffffff" stroke="#6fc98a" stroke-width="1.8"/>
        <text x="332" y="92" text-anchor="middle" font-family="Roboto" font-weight="500" font-size="11.5" fill="#436743">Dato causale di lotto</text>
        <text x="332" y="108" text-anchor="middle" font-family="Roboto" font-size="9" fill="#5c6b62">triple: provenienza · spettro · esito</text>
        <text x="332" y="121" text-anchor="middle" font-family="Roboto" font-size="9" fill="#5c6b62">cresce a ogni lotto</text>
        <!-- esito misurato (verde-soft) -->
        <rect x="486" y="28" width="142" height="54" rx="8" fill="#c7ebd2" stroke="#6fc98a"/>
        <text x="557" y="50" text-anchor="middle" font-family="Roboto" font-weight="500" font-size="11" fill="#436743">Esito misurato</text>
        <text x="557" y="66" text-anchor="middle" font-family="Roboto" font-size="9" fill="#436743">OSI · Rancimat</text>
        <!-- passaporto -->
        <rect x="486" y="110" width="142" height="54" rx="8" fill="#ffffff" stroke="#6fc98a"/>
        <text x="557" y="132" text-anchor="middle" font-family="Roboto" font-weight="500" font-size="11" fill="#436743">Passaporto</text>
        <text x="557" y="148" text-anchor="middle" font-family="Roboto" font-size="9" fill="#436743">stabilità prevista</text>
        <!-- arrows in -->
        <path d="M170 56 C206 66, 224 80, 246 90" fill="none" stroke="#2f5a44" stroke-width="1.4"/><polygon points="243,86 249,90 242,93" fill="#2f5a44"/>
        <path d="M170 136 C206 126, 224 112, 246 102" fill="none" stroke="#2f5a44" stroke-width="1.4"/><polygon points="243,105 249,102 242,98" fill="#2f5a44"/>
        <!-- arrows out -->
        <path d="M418 90 C450 80, 466 66, 486 58" fill="none" stroke="#2f5a44" stroke-width="1.4"/><polygon points="483,54 489,57 482,61" fill="#2f5a44"/>
        <path d="M418 112 C450 122, 466 128, 486 134" fill="none" stroke="#2f5a44" stroke-width="1.4"/><polygon points="482,130 489,134 481,137" fill="#2f5a44"/>
        <!-- feedback: esito addestra il modello -->
        <path d="M557 82 C557 184, 332 196, 332 134" fill="none" stroke="#2f5a44" stroke-width="1.1" stroke-dasharray="4 3"/><polygon points="328.5,138 335.5,138 332,132" fill="#2f5a44"/>
        <text x="362" y="192" font-family="Roboto" font-style="italic" font-size="8.4" fill="rgba(28,38,32,.55)">l'esito misurato addestra il modello, lotto dopo lotto</text>
      </svg>
      <figcaption>
        I metodi accreditati come il Rancimat agiscono da generatore di ground truth che addestra il
        modello. La provenienza, che nessun laboratorio possiede, entra come variabile di ingresso.
        <DataTag kind="fonte" label="Rancimat / Oxidation Stability Index · ISO 6886, AOCS Cd 12b-92" />
      </figcaption>
    </figure>

    <p>
      Il braccio "provenienza" del dataset si costruisce solo restando dentro la filiera certificata:
      richiede accesso e fiducia territoriale, non capitale. L'esito misurato si accumula a ogni lotto, e
      la combinazione cresce per effetto rete man mano che altri partner di filiera entrano. La materia
      prima prevalente è il <strong>sego bovino delle vacche da latte del Parmigiano Reggiano</strong>, di
      cui dieta, movimento e storia sono noti; il grasso suino resta una matrice affine e secondaria.
    </p>
  </Section>

  <Section n="3" title="Acquisizione governata">
    <p>
      Le matrici lipidiche sono sporche, semi-solide, fluorescenti e termicamente instabili. AMSA
      <strong>governa la misura</strong> per ottenere il dato migliore, invece di subirla. Nella versione
      3 questa capacità parte nella forma più solida e verificabile per la fase attuale: una SOP a regole
      sulle soglie di qualità e incertezza.
    </p>

    <ControlLoop
      inputLabel="Campione"
      loopLabel="itera finché il QC è accettabile o si raggiunge il limite"
      loopNodes={['Scout scan', 'Quality Assessor', 'Regole su soglie', 'Azione sicura']}
      exitGate="QC ok"
      predict="Predizione + XAI"
      outcome="Passaporto Lipidico Digitale"
    />

    <p>
      Alcune azioni, il riscaldamento in primo luogo, alterano lo stato chimico del campione e sono
      irreversibili. Restano governate da vincoli rigidi e da uno shielding deterministico: nessuna azione
      che possa degradare il materiale oltre soglia viene eseguita, ancorata alla soglia Codex CXS
      211-1999 (perossidi al massimo 10 meq O₂/kg) <DataTag kind="fonte" label="Codex Alimentarius CXS 211-1999" />.
    </p>
    <p>
      Una <strong>politica appresa</strong> entra solo dove una SOP fissa ben disegnata mostra un margine
      di miglioramento misurabile e il dataset ha dimensione sufficiente. Fino ad allora la SOP a regole
      offre il miglior rapporto fra valore e complessità, e produce proprio i dati che addestreranno
      l'eventuale politica.
    </p>
  </Section>

  <Section n="4" title="Passaporto Lipidico Digitale">
    <p>
      Il prodotto informativo centrale di AMSA, nella versione 3 <strong>predittivo e ancorato alla
      provenienza</strong>. Per ogni lotto collega identità, origine, spettri, analisi di riferimento,
      biomarcatori, stabilità prevista con confidenza, raccomandazione di processo, spiegazione
      interpretabile e governance del dato.
    </p>
    <PassportSections sections={passport} />
    <p class="note legend">
      <span class="ode-tag ode-tag--fonte">Misurato</span>
      <span class="ode-tag ode-tag--stima">Predetto</span>
      Ogni campo è marcato come misurato (metodo di riferimento) o predetto (output di modello con
      intervallo a copertura garantita). I campi predetti migliorano con la validazione del modello causale.
    </p>
    <div class="caveat">
      <span class="caveat-k">Aspettativa calibrata</span>
      <p>La velocità di ossidazione dipende anche da condizioni esogene (stoccaggio, packaging, luce,
      ossigeno) che lo spettro non cattura. La provenienza ne riduce una parte a monte, l'esito misurato
      la calibra a valle, e ogni stabilità prevista è riportata con il suo intervallo di confidenza. Dove
      serve, il passaporto raccomanda il test confermativo.</p>
    </div>
    <div class="twodir">
      <article class="dir">
        <span class="dir-k">Direzione descrittiva</span>
        <p>Qualità in ingresso, passaporto in uscita: il lotto arriva, AMSA misura, predice, spiega e
        decide (accetta, purifica, deodora, miscela, testa esternamente o scarta).</p>
      </article>
      <article class="dir alt">
        <span class="dir-k">Direzione a specifica</span>
        <p>Requisito in ingresso, campione in uscita: arriva una tenuta target, AMSA la traduce in una
        specifica di stabilità, guida il processo per centrarla, conferma con test accelerato e certifica.</p>
      </article>
    </div>
  </Section>

  <Section n="5" title="Posizionamento e fossato">
    <p>
      I compratori cosmetici B2B e i loro valutatori lavorano dentro quadri accreditati (ISO 17025,
      valutazione di sicurezza, test di stabilità secondo norma). AMSA si colloca <strong>accanto al
      laboratorio accreditato</strong>, come acceleratore del metodo e strato di provenienza, in
      complemento al test di riferimento.
    </p>
    <div class="roles">
      {roles.map((rl) => (
        <article class="role">
          <span class="role-k">{rl.k}</span>
          <p>{rl.d}</p>
        </article>
      ))}
    </div>
    <p>
      Il fossato è di <strong>dato e di accesso, non di algoritmo</strong>. Strumenti, metodi e
      contenitore del passaporto sono replicabili in pochi mesi. Restano inattaccabili l'accesso alla
      filiera tracciata e il dataset causale che ne deriva: due asset che un concorrente con sego anonimo
      non può comprare.
    </p>
    <div class="stats">
      <StatCard value="> 0,85" caption="Target R² per l'indice di insaturazione (proxy iodine value); in letteratura Raman fino a 0,97." kind="stima" source="Target di piano; benchmark Beattie et al., 2006" />
      <StatCard value="≈ 0,73" caption="R² medio atteso sui singoli acidi grassi (limite da covarianza biologica): il dettaglio resta all'escalation GC-FID." kind="fonte" source="Letteratura NIR/Raman su acidi grassi" />
      <StatCard value="+20–40%" caption="Ipotesi di premio di prezzo rispetto a un ingrediente lipidico non qualificato, da validare sui dati di mercato." kind="stima" source="Ipotesi di piano OdE, da validare" />
    </div>
    <p class="note">Il premio di prezzo è un'ipotesi di piano, da validare sui dati di <a href="/OdE/mercato">Mercato</a>.</p>
    <p class="quote big">"Un concorrente può comprare uno spettrometro, non l'accesso alla filiera né il dato causale che ne deriva."</p>
  </Section>

  <a class="deepdive" href="/OdE/amsa/tecnica">
    <span class="dd-k">Approfondimento tecnico</span>
    <span class="dd-t">Sotto il cofano di AMSA →</span>
    <span class="dd-d">Data ladder, foundation model lipidico, i tre motori predittivi, fiducia quantificata e l'esperimento decisivo provenienza verso stabilità. Per scienziati e R&D.</span>
  </a>
</OdeLayout>

<style>
  .hero { max-width: 44rem; padding: 0.5rem 0 1rem; }
  .hero h1 { font-size: clamp(2.4rem, 6vw, 3.4rem); margin: 0.4rem 0 1rem; }
  .lede { font-size: 1.1rem; line-height: 1.6; color: var(--body); }
  .verbs { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.4rem; }
  .verb {
    font-family: var(--ode-font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--pill);
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
  }
  .problems { padding-left: 1.2rem; line-height: 1.7; max-width: 42rem; }
  .problems li { margin-bottom: 0.4rem; }
  .problems li::marker { color: var(--accent); }
  .quote {
    border-left: 3px solid var(--lav-border);
    padding: 0.4rem 0 0.4rem 1rem;
    color: var(--body);
    font-style: italic;
    background: rgba(255, 255, 255, 0.28);
    border-radius: 0 var(--ode-radius) var(--ode-radius) 0;
  }
  .quote.big { font-size: 1.2rem; font-style: italic; }

  .note { font-size: 0.85rem; color: var(--muted); line-height: 1.5; max-width: 44rem; }
  .note a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .note .ode-tag { margin-right: 0.3rem; }
  .caveat {
    background: rgba(255, 255, 255, 0.34);
    border-left: 3px solid var(--green-border);
    border-radius: 0 var(--ode-radius) var(--ode-radius) 0;
    padding: 0.8rem 1rem; margin: 1rem 0; max-width: 44rem;
  }
  .caveat-k { display: block; font-family: var(--ode-font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--accent); margin-bottom: 0.3rem; }
  .caveat p { margin: 0; font-size: 0.92rem; line-height: 1.55; color: var(--body); }

  .diagram { margin: 1.4rem 0; }
  .diagram svg { width: 100%; height: auto; display: block; }
  .diagram figcaption { font-size: 0.85rem; color: var(--muted); line-height: 1.5; margin-top: 0.6rem; max-width: 44rem; }

  .twodir { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; margin-top: 1.2rem; }
  .dir { border-left: 3px solid var(--green-border); padding: 0.2rem 0 0.2rem 1rem; }
  .dir.alt { border-left-color: var(--pink); }
  .dir-k { font-family: var(--ode-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); }
  .dir.alt .dir-k { color: var(--pink-ink); }
  .dir p { margin: 0.4rem 0 0; font-size: 0.92rem; line-height: 1.5; color: var(--body); }

  .roles { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; margin: 1.2rem 0; }
  .role { background: var(--panel); border: 1px solid var(--rule); border-radius: var(--ode-radius); padding: 1.1rem 1.2rem; }
  .role-k { display: block; font-weight: 500; color: var(--accent); margin-bottom: 0.4rem; }
  .role p { margin: 0; font-size: 0.9rem; line-height: 1.5; color: var(--body); }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.8rem;
    margin: 1.4rem 0;
  }
  .deepdive {
    display: block;
    text-decoration: none;
    background: var(--green-soft);
    border: 1px solid var(--green-border);
    border-radius: var(--ode-radius);
    padding: 1.3rem 1.5rem;
    margin-top: 1rem;
    transition: transform 160ms ease;
  }
  .deepdive:hover { transform: translateY(-2px); }
  .dd-k { display: block; font-family: var(--ode-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); }
  .dd-t { display: block; font-size: 1.2rem; color: var(--ink); margin: 0.3rem 0; }
  .dd-d { display: block; font-size: 0.9rem; line-height: 1.5; color: var(--body); max-width: 40rem; }
</style>
