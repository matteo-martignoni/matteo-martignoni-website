---
import OdeLayout from '../../layouts/OdeLayout.astro';
import SectionStub from '../../components/ode/SectionStub.astro';
import { odeMeta } from '../../i18n/ode';
const lang = 'it' as const;
const m = odeMeta[lang].mercato;
---
<OdeLayout title={m.title} description={m.description} lang={lang} active="mercato">
  <SectionStub
    lang={lang}
    n="02"
    title="Validazione di mercato"
    summary="La domanda di ingredienti cosmetici upcycled e tracciabili è in forte crescita, e l'incrocio fra lipide animale circolare e controllo qualità AI-driven è una nicchia ancora poco presidiata."
    willContain={[
      'Dimensione dei mercati di riferimento e tassi di crescita (CAGR)',
      'Trend e driver: upcycling cosmetico, disponibilità a pagare, premium di prezzo',
      'Competizione su tre assi (materia prima, prodotto finito, tecnologia)',
      'Orologio normativo: Digital Product Passport obbligatorio dal 2027',
      'Visualizzazioni: grafici di crescita, tabella comparativa competitor',
    ]}
  />
</OdeLayout>
