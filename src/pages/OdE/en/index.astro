---
import OdeLayout from '../../../layouts/OdeLayout.astro';
import { odeMeta, odeRoutes } from '../../../i18n/ode';

const lang = 'en' as const;
const m = odeMeta[lang].home;
const r = odeRoutes[lang];

const ideas = [
  {
    k: 'Circularity',
    body: 'Fats and by-products that today are worth little become ultra-pure lipid ingredients. Everything is recovered and qualified.',
  },
  {
    k: 'Territory',
    body: 'The raw material comes from the certified Parmigiano Reggiano supply chains: traceable from the barn, ethically transparent. A defensible advantage, rooted in the territory.',
  },
  {
    k: 'Technology',
    body: 'AMSA, artificial intelligence and multimodal spectroscopy, reads every batch and certifies its quality, stability and process in a Digital Lipid Passport.',
  },
];

// Navigation to the spine sections (the what). Names are distinct from the
// "The vision" ideas: no word repeats between the two sections.
const sections = [
  { href: r.amsa, title: 'AMSA', desc: 'The multimodal spectroscopic agent that reads every batch and signs its Digital Lipid Passport.' },
  { href: r.mercato, title: 'Market', desc: 'The validation: size, trends, competition and the Digital Product Passport regulatory window.' },
  { href: r.visione, title: 'Trajectory', desc: 'From niche producer to multi-market qualification supplier: AMSA’s three blue oceans.' },
];

// The two doors, one per audience. Visually distinct from the spine cards.
const doors = [
  { href: r.investitori, title: 'Investors', desc: 'The investment thesis, the incentives for innovative startups in Italy and the routes open to non-EU investors.' },
  { href: r.ricerca, title: 'Research', desc: 'The open questions, the method and the decisive provenance-to-stability experiment: an invitation to research groups.' },
];
---
<OdeLayout title={m.title} description={m.description} lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <h1>From an animal by-product, a precision cosmetic ingredient.</h1>
      <p class="lede">
        Officina degli Estratti is a deep-tech circular-bioeconomy startup in Langhirano, near Parma.
        It upcycles fats and by-products from local animal supply chains into ultra-pure lipid
        ingredients for B2B cosmetics, with a Digital Lipid Passport that certifies every single batch.
      </p>
    </div>
    <figure class="hero-art">
      <img
        src="/images/ode/mucca-maiale.png"
        alt="Single-line illustration of a cow and a pig, the two animal supply chains OdE’s raw material comes from."
        width="1448"
        height="1086"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="block" aria-label="The vision">
    <p class="ode-eyebrow block-eyebrow">The vision</p>
    <div class="ideas">
      {ideas.map((idea) => (
        <article class="idea">
          <h2>{idea.k}</h2>
          <p>{idea.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="block" aria-label="Explore the project">
    <p class="ode-eyebrow block-eyebrow">Explore the project</p>
    <nav class="pillars" aria-label="Project sections">
      {sections.map((p) => (
        <a class="pillar" href={p.href}>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-desc">{p.desc}</span>
        </a>
      ))}
    </nav>
  </section>

  <section class="block" aria-label="The two doors">
    <p class="ode-eyebrow block-eyebrow">Two doors, two audiences</p>
    <nav class="doors" aria-label="Investors and research">
      {doors.map((d) => (
        <a class="door" href={d.href}>
          <span class="door-title">{d.title}<span class="door-arrow" aria-hidden="true">→</span></span>
          <span class="door-desc">{d.desc}</span>
        </a>
      ))}
    </nav>
  </section>
</OdeLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 1rem 0 2rem;
  }
  .hero-text { max-width: 34rem; }
  .hero h1 { font-size: clamp(2rem, 4.4vw, 3rem); letter-spacing: -0.01em; }
  .lede { font-size: 1.05rem; line-height: 1.6; color: var(--ode-body); margin: 1.25rem 0 0; }
  .hero-art { margin: 0; }
  .hero-art img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply;
    animation: art-in 900ms ease both;
  }
  @keyframes art-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .block { padding: 2.2rem 0; border-top: 1px solid var(--ode-rule); }
  .block-eyebrow { margin: 0 0 1.3rem; }

  .ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2rem;
  }
  .idea h2 { font-size: 1.05rem; font-weight: 500; color: var(--ode-accent); margin: 0 0 0.5rem; }
  .idea p { font-size: 0.95rem; line-height: 1.55; color: var(--ode-body); margin: 0; }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--ode-surface);
    border: 1px solid var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .pillar:hover { border-color: var(--ode-accent); transform: translateY(-2px); }
  .pillar-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); }
  .pillar-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  /* The two audience doors: distinct from the spine cards — green-soft,
     accent-bordered, with an arrow that signals "an entry point". */
  .doors { display: grid; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); gap: 1rem; }
  .door {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--green-soft);
    border: 1px solid var(--green-border);
    border-radius: var(--ode-radius);
    padding: 1.4rem 1.5rem;
    transition: transform 160ms ease;
  }
  .door:hover { transform: translateY(-2px); }
  .door-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .door-arrow { color: var(--accent); font-size: 1.1rem; }
  .door-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  @media (max-width: 700px) {
    .hero { grid-template-columns: 1fr; gap: 1rem; }
    .hero-art { order: -1; max-width: 24rem; }
  }
</style>
