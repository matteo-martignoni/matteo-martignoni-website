---
import OdeLayout from '../../../layouts/OdeLayout.astro';
import { odeMeta, odeUI, odeRoutes } from '../../../i18n/ode';

const lang = 'en' as const;
const m = odeMeta[lang].home;
const t = odeUI[lang];
const r = odeRoutes[lang];

const ideas = [
  {
    k: 'Circularity',
    body: 'Fats and by-products that today are worth little become ultra-pure lipid ingredients. Everything is recovered and qualified.',
  },
  {
    k: 'Territory',
    body: 'The raw material comes from the certified Parmigiano Reggiano supply chains: traceable from the barn, ethically transparent. A defensible advantage, rooted in the territory.',
  },
  {
    k: 'Technology',
    body: 'AMSA, artificial intelligence and multimodal spectroscopy, reads every batch and certifies its quality, stability and process in a Digital Lipid Passport.',
  },
];

const pillars = [
  { href: r.amsa, n: '01', title: 'AMSA', desc: 'The technology: AI-driven multimodal spectroscopic agent, Active Control Loop, Digital Lipid Passport.' },
  { href: r.mercato, n: '02', title: 'Market', desc: 'The validation: size, trends, competition and the Digital Product Passport regulatory window.' },
  { href: r.visione, n: '03', title: 'Vision', desc: 'The trajectory: from producer to multi-market supplier, AMSA’s three blue oceans.' },
];
const secondary = [
  { href: r.normativa, label: 'Regulatory Clock' },
  { href: r.tracciabilita, label: 'Traceability' },
  { href: r.investitori, label: 'Investors' },
  { href: r.glossario, label: 'Glossary' },
];
---
<OdeLayout title={m.title} description={m.description} lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <p class="kicker">{t.tagline}</p>
      <h1>From an animal by-product, a precision cosmetic ingredient.</h1>
      <p class="lede">
        Officina degli Estratti is a deep-tech circular-bioeconomy startup in Langhirano, near Parma.
        It upcycles fats and by-products from local animal supply chains into ultra-pure lipid
        ingredients for B2B cosmetics, with a Digital Lipid Passport that certifies every single batch.
      </p>
      <a class="cta" href={r.amsa}>Discover AMSA →</a>
    </div>
    <figure class="hero-art">
      <img
        src="/images/ode/mucca-maiale.png"
        alt="Single-line illustration of a cow and a pig, the two animal supply chains OdE’s raw material comes from."
        width="1448"
        height="1086"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="ideas" aria-label="The vision">
    {ideas.map((idea) => (
      <article class="idea">
        <h2>{idea.k}</h2>
        <p>{idea.body}</p>
      </article>
    ))}
  </section>

  <nav class="pillars" aria-label="Sections">
    {pillars.map((p) => (
      <a class="pillar" href={p.href}>
        <span class="pillar-n">{p.n}</span>
        <span class="pillar-title">{p.title}</span>
        <span class="pillar-desc">{p.desc}</span>
      </a>
    ))}
  </nav>

  <nav class="secondary" aria-label="Deep dives">
    {secondary.map((s) => (
      <a class="sec-door" href={s.href}>{s.label} →</a>
    ))}
    <a class="sec-door sec-live" href={r.live}>{t.cta.explore} →</a>
  </nav>
</OdeLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 1rem 0 2.5rem;
  }
  .hero-text { max-width: 34rem; }
  .kicker {
    font-family: var(--ode-font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--ode-muted);
    margin: 0 0 1rem;
  }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); letter-spacing: -0.01em; }
  .lede { font-size: 1.05rem; line-height: 1.6; color: var(--ode-body); margin: 1.25rem 0 1.75rem; }
  .cta {
    display: inline-block;
    text-decoration: none;
    background: var(--ode-accent);
    color: var(--ode-accent-ink);
    padding: 0.7rem 1.2rem;
    border-radius: var(--ode-radius);
    font-size: 0.9rem;
  }
  .hero-art { margin: 0; }
  .hero-art img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply;
    animation: art-in 900ms ease both;
  }
  @keyframes art-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2rem;
    margin: 1rem 0 3rem;
    padding: 2rem 0;
    border-top: 1px solid var(--ode-rule);
    border-bottom: 1px solid var(--ode-rule);
  }
  .idea h2 { font-size: 1.05rem; font-weight: 500; color: var(--ode-accent); margin: 0 0 0.5rem; }
  .idea p { font-size: 0.95rem; line-height: 1.55; color: var(--ode-body); margin: 0; }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--ode-surface);
    border: 1px solid var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .pillar:hover { border-color: var(--ode-accent); transform: translateY(-2px); }
  .pillar-n { font-family: var(--ode-font-mono); font-size: 0.8rem; color: var(--ode-muted); }
  .pillar-title { font-size: 1.3rem; font-weight: 600; color: var(--ode-ink); }
  .pillar-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  .secondary { display: flex; flex-wrap: wrap; gap: 0.6rem 1.4rem; margin-top: 1.5rem; }
  .sec-door {
    font-size: 0.85rem;
    color: var(--ode-muted);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .sec-door:hover { color: var(--ode-accent); }
  .sec-live { color: var(--ode-accent); }

  @media (max-width: 700px) {
    .hero { grid-template-columns: 1fr; gap: 1rem; }
    .hero-art { order: -1; max-width: 24rem; }
  }
</style>
