---
import OdeLayout from '../../../layouts/OdeLayout.astro';
import { odeMeta, odeRoutes } from '../../../i18n/ode';

const lang = 'en' as const;
const m = odeMeta[lang].home;
const r = odeRoutes[lang];

const ideas = [
  {
    k: 'Circularity',
    body: 'Fats and by-products that today are worth little become ultra-pure lipid ingredients. Everything is recovered and qualified.',
  },
  {
    k: 'Territory',
    body: 'The raw material comes from the certified Parmigiano Reggiano supply chains: traceable from the barn, ethically transparent. A defensible advantage, rooted in the territory.',
  },
  {
    k: 'Technology',
    body: 'AMSA, artificial intelligence and multimodal spectroscopy, reads every batch and certifies its quality, stability and process in a Digital Lipid Passport.',
  },
];

const pillars = [
  { href: r.amsa, n: 'Pillar 01', title: 'Technology', desc: 'Multimodal spectroscopic agent, the chain causal datum and Digital Lipid Passport: the technological core of OdE.' },
  { href: r.mercato, n: 'Pillar 02', title: 'Market', desc: 'The validation: size, trends, competition and the Digital Product Passport regulatory window.' },
  { href: r.visione, n: 'Pillar 03', title: 'Vision', desc: 'The trajectory: from producer to multi-market supplier, AMSA’s three blue oceans.' },
];
---
<OdeLayout title={m.title} description={m.description} lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <h1>From an animal by-product, a precision cosmetic ingredient.</h1>
      <p class="lede">
        Officina degli Estratti is a deep-tech circular-bioeconomy startup in Langhirano, near Parma.
        It upcycles fats and by-products from local animal supply chains into ultra-pure lipid
        ingredients for B2B cosmetics, with a Digital Lipid Passport that certifies every single batch.
      </p>
    </div>
    <figure class="hero-art">
      <img
        src="/images/ode/mucca-maiale.png"
        alt="Single-line illustration of a cow and a pig, the two animal supply chains OdE’s raw material comes from."
        width="1448"
        height="1086"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="block" aria-label="The vision">
    <p class="ode-eyebrow block-eyebrow">The vision</p>
    <div class="ideas">
      {ideas.map((idea) => (
        <article class="idea">
          <h2>{idea.k}</h2>
          <p>{idea.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="block" aria-label="The pillars">
    <p class="ode-eyebrow block-eyebrow">The three pillars</p>
    <nav class="pillars" aria-label="Project sections">
      {pillars.map((p) => (
        <a class="pillar" href={p.href}>
          <span class="pillar-n">{p.n}</span>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-desc">{p.desc}</span>
        </a>
      ))}
    </nav>
  </section>
</OdeLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 1rem 0 2rem;
  }
  .hero-text { max-width: 34rem; }
  .hero h1 { font-size: clamp(2rem, 4.4vw, 3rem); letter-spacing: -0.01em; }
  .lede { font-size: 1.05rem; line-height: 1.6; color: var(--ode-body); margin: 1.25rem 0 0; }
  .hero-art { margin: 0; }
  .hero-art img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply;
    animation: art-in 900ms ease both;
  }
  @keyframes art-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .block { padding: 2.2rem 0; border-top: 1px solid var(--ode-rule); }
  .block-eyebrow { margin: 0 0 1.3rem; }

  .ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2rem;
  }
  .idea h2 { font-size: 1.05rem; font-weight: 500; color: var(--ode-accent); margin: 0 0 0.5rem; }
  .idea p { font-size: 0.95rem; line-height: 1.55; color: var(--ode-body); margin: 0; }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--ode-surface);
    border: 1px solid var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .pillar:hover { border-color: var(--ode-accent); transform: translateY(-2px); }
  .pillar-n { font-family: var(--ode-font-mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ode-muted); }
  .pillar-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); }
  .pillar-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  @media (max-width: 700px) {
    .hero { grid-template-columns: 1fr; gap: 1rem; }
    .hero-art { order: -1; max-width: 24rem; }
  }
</style>
