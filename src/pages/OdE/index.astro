---
import OdeLayout from '../../layouts/OdeLayout.astro';
import { odeMeta, odeRoutes } from '../../i18n/ode';

const lang = 'it' as const;
const m = odeMeta[lang].home;
const r = odeRoutes[lang];

// La visione in tre parole (alta narrazione prima dei tecnicismi).
const ideas = [
  {
    k: 'Circolarità',
    body: 'Grassi e sottoprodotti che oggi valgono poco diventano ingredienti lipidici ultrapuri. Tutto si recupera e si qualifica.',
  },
  {
    k: 'Territorio',
    body: 'La materia prima nasce dalle filiere certificate del Parmigiano Reggiano: tracciabile dalla stalla, eticamente trasparente. Un vantaggio difendibile, radicato nel territorio.',
  },
  {
    k: 'Tecnologia',
    body: 'AMSA, intelligenza artificiale e spettroscopia multimodale, legge ogni lotto e ne certifica qualità, stabilità e processo in un Passaporto Lipidico Digitale.',
  },
];

// Navigazione alle sezioni di spina (il cosa). I nomi sono distinti dalle
// idee di "La visione": nessuna parola si ripete fra le due sezioni.
const sections = [
  { href: r.amsa, title: 'AMSA', desc: 'L’agente spettroscopico multimodale che legge ogni lotto e ne firma il Passaporto Lipidico Digitale.' },
  { href: r.mercato, title: 'Mercato', desc: 'La validazione: dimensione, trend, competizione e la finestra normativa del Digital Product Passport.' },
  { href: r.visione, title: 'Sviluppo', desc: 'Da produttore di nicchia a fornitore di qualificazione multi-mercato: i tre spazi azzurri di AMSA.' },
];

// Le due porte, una per pubblico. Visivamente distinte dalle sezioni di spina.
const doors = [
  { href: r.investitori, title: 'Investitori', desc: 'La tesi di investimento, gli incentivi per le startup innovative in Italia e i percorsi per investitori extra-UE.' },
  { href: r.ricerca, title: 'Ricerca', desc: 'Le domande aperte, il metodo e l’esperimento decisivo provenienza verso stabilità: un invito ai gruppi di ricerca.' },
];
---
<OdeLayout title={m.title} description={m.description} lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <h1>Dal sottoprodotto animale, un ingrediente cosmetico di precisione.</h1>
      <p class="lede">
        Officina degli Estratti è una startup deep-tech di bioeconomia circolare a Langhirano, Parma.
        Valorizza grassi e sottoprodotti delle filiere animali locali in ingredienti lipidici ultrapuri
        per la cosmetica B2B, con un Passaporto Lipidico Digitale che certifica ogni singolo lotto.
      </p>
    </div>
    <figure class="hero-art">
      <img
        src="/images/ode/mucca-maiale.png"
        alt="Illustrazione a tratto unico di una mucca e un maiale, le due filiere animali da cui nasce la materia prima di OdE."
        width="1448"
        height="1086"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="block" aria-label="La visione">
    <p class="ode-eyebrow block-eyebrow">La visione</p>
    <div class="ideas">
      {ideas.map((idea) => (
        <article class="idea">
          <h2>{idea.k}</h2>
          <p>{idea.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="block" aria-label="Esplora il progetto">
    <p class="ode-eyebrow block-eyebrow">Esplora il progetto</p>
    <nav class="pillars" aria-label="Sezioni del progetto">
      {sections.map((p) => (
        <a class="pillar" href={p.href}>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-desc">{p.desc}</span>
        </a>
      ))}
    </nav>
  </section>

  <section class="block" aria-label="Le due porte">
    <p class="ode-eyebrow block-eyebrow">Due porte, due pubblici</p>
    <nav class="doors" aria-label="Investitori e ricerca">
      {doors.map((d) => (
        <a class="door" href={d.href}>
          <span class="door-title">{d.title}<span class="door-arrow" aria-hidden="true">→</span></span>
          <span class="door-desc">{d.desc}</span>
        </a>
      ))}
    </nav>
  </section>
</OdeLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 1rem 0 2rem;
  }
  .hero-text { max-width: 34rem; }
  .hero h1 { font-size: clamp(2rem, 4.4vw, 3rem); letter-spacing: -0.01em; }
  .lede { font-size: 1.05rem; line-height: 1.6; color: var(--ode-body); margin: 1.25rem 0 0; }
  .hero-art { margin: 0; }
  .hero-art img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply; /* drop the white fringe, let the line sit on mint */
    animation: art-in 900ms ease both;
  }
  @keyframes art-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .block { padding: 2.2rem 0; border-top: 1px solid var(--ode-rule); }
  .block-eyebrow { margin: 0 0 1.3rem; }

  .ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2rem;
  }
  .idea h2 { font-size: 1.05rem; font-weight: 500; color: var(--ode-accent); margin: 0 0 0.5rem; }
  .idea p { font-size: 0.95rem; line-height: 1.55; color: var(--ode-body); margin: 0; }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--ode-surface);
    border: 1px solid var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .pillar:hover { border-color: var(--ode-accent); transform: translateY(-2px); }
  .pillar-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); }
  .pillar-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  /* The two audience doors: distinct from the spine cards — green-soft,
     accent-bordered, with an arrow that signals "an entry point". */
  .doors { display: grid; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); gap: 1rem; }
  .door {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--green-soft);
    border: 1px solid var(--green-border);
    border-radius: var(--ode-radius);
    padding: 1.4rem 1.5rem;
    transition: transform 160ms ease;
  }
  .door:hover { transform: translateY(-2px); }
  .door-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem; }
  .door-arrow { color: var(--accent); font-size: 1.1rem; }
  .door-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  @media (max-width: 700px) {
    .hero { grid-template-columns: 1fr; gap: 1rem; }
    .hero-art { order: -1; max-width: 24rem; }
  }
</style>
