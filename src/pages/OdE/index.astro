---
import OdeLayout from '../../layouts/OdeLayout.astro';
import { odeMeta, odeRoutes } from '../../i18n/ode';

const lang = 'it' as const;
const m = odeMeta[lang].home;
const r = odeRoutes[lang];

// La visione in tre parole (alta narrazione prima dei tecnicismi).
const ideas = [
  {
    k: 'Circolarità',
    body: 'Grassi e sottoprodotti che oggi valgono poco diventano ingredienti lipidici ultrapuri. Tutto si recupera e si qualifica.',
  },
  {
    k: 'Territorio',
    body: 'La materia prima nasce dalle filiere certificate del Parmigiano Reggiano: tracciabile dalla stalla, eticamente trasparente. Un vantaggio difendibile, radicato nel territorio.',
  },
  {
    k: 'Tecnologia',
    body: 'AMSA, intelligenza artificiale e spettroscopia multimodale, legge ogni lotto e ne certifica qualità, stabilità e processo in un Passaporto Lipidico Digitale.',
  },
];

// I tre pilastri di approfondimento.
const pillars = [
  { href: r.amsa, n: 'Pilastro 01', title: 'Tecnologia', desc: 'Agente spettroscopico multimodale, Active Control Loop e Passaporto Lipidico Digitale: il motore tecnologico di OdE.' },
  { href: r.mercato, n: 'Pilastro 02', title: 'Mercato', desc: 'La validazione: dimensione, trend, competizione e la finestra normativa del Digital Product Passport.' },
  { href: r.visione, n: 'Pilastro 03', title: 'Visione', desc: 'Lo sviluppo: da produttore a fornitore multi-mercato, i tre spazi azzurri di AMSA.' },
];
---
<OdeLayout title={m.title} description={m.description} lang={lang}>
  <section class="hero">
    <div class="hero-text">
      <h1>Dal sottoprodotto animale, un ingrediente cosmetico di precisione.</h1>
      <p class="lede">
        Officina degli Estratti è una startup deep-tech di bioeconomia circolare a Langhirano, Parma.
        Valorizza grassi e sottoprodotti delle filiere animali locali in ingredienti lipidici ultrapuri
        per la cosmetica B2B, con un Passaporto Lipidico Digitale che certifica ogni singolo lotto.
      </p>
    </div>
    <figure class="hero-art">
      <img
        src="/images/ode/mucca-maiale.png"
        alt="Illustrazione a tratto unico di una mucca e un maiale, le due filiere animali da cui nasce la materia prima di OdE."
        width="1448"
        height="1086"
        loading="eager"
        decoding="async"
      />
    </figure>
  </section>

  <section class="block" aria-label="La visione">
    <p class="ode-eyebrow block-eyebrow">La visione</p>
    <div class="ideas">
      {ideas.map((idea) => (
        <article class="idea">
          <h2>{idea.k}</h2>
          <p>{idea.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="block" aria-label="I pilastri">
    <p class="ode-eyebrow block-eyebrow">I tre pilastri</p>
    <nav class="pillars" aria-label="Sezioni del progetto">
      {pillars.map((p) => (
        <a class="pillar" href={p.href}>
          <span class="pillar-n">{p.n}</span>
          <span class="pillar-title">{p.title}</span>
          <span class="pillar-desc">{p.desc}</span>
        </a>
      ))}
    </nav>
  </section>
</OdeLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: center;
    padding: 1rem 0 2rem;
  }
  .hero-text { max-width: 34rem; }
  .hero h1 { font-size: clamp(2rem, 4.4vw, 3rem); letter-spacing: -0.01em; }
  .lede { font-size: 1.05rem; line-height: 1.6; color: var(--ode-body); margin: 1.25rem 0 0; }
  .hero-art { margin: 0; }
  .hero-art img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply; /* drop the white fringe, let the line sit on mint */
    animation: art-in 900ms ease both;
  }
  @keyframes art-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .block { padding: 2.2rem 0; border-top: 1px solid var(--ode-rule); }
  .block-eyebrow { margin: 0 0 1.3rem; }

  .ideas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem 2rem;
  }
  .idea h2 { font-size: 1.05rem; font-weight: 500; color: var(--ode-accent); margin: 0 0 0.5rem; }
  .idea p { font-size: 0.95rem; line-height: 1.55; color: var(--ode-body); margin: 0; }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); gap: 1rem; }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    background: var(--ode-surface);
    border: 1px solid var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }
  .pillar:hover { border-color: var(--ode-accent); transform: translateY(-2px); }
  .pillar-n { font-family: var(--ode-font-mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ode-muted); }
  .pillar-title { font-size: 1.3rem; font-weight: 500; color: var(--ode-ink); }
  .pillar-desc { font-size: 0.9rem; line-height: 1.5; color: var(--ode-body); }

  @media (max-width: 700px) {
    .hero { grid-template-columns: 1fr; gap: 1rem; }
    .hero-art { order: -1; max-width: 24rem; }
  }
</style>
