---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter(item => item.data.lang === 'en')
  .sort((a, b) => a.data.order - b.data.order);

const renderedProjects = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await render(project);
    return { data: project.data, Content };
  })
);
---
<BaseLayout
  title="Brand Projects: Diesel, Aēsop, Uniqlo — Matteo Martignoni"
  description="Twenty-five years of brand work in ten chapters, across four countries."
  lang="en"
>
  <SectionHero
    number="02"
    tagline="The work, in chapters"
    title="Twenty-five years. Ten projects. Four countries."
    intro="Three of them I founded with head, heart, and hands together. The others I led for someone else's vision."
  />

  <!-- CV download — discreet text CTA in the site's link idiom -->
  <div class="max-w-3xl mt-8 md:mt-10">
    <a
      href="/cv/Matteo-Martignoni-CV-EN.pdf"
      download
      class="inline-flex items-center gap-2.5 text-xs uppercase tracking-wider text-terracotta-900 hover:text-terracotta-700 transition-colors duration-200"
    >
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <line x1="8" y1="2" x2="8" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M4 7.5 8 11.5 12 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="3.5" y1="14" x2="12.5" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span>Download CV (PDF)</span>
    </a>
  </div>

  <section class="max-w-3xl mt-12 md:mt-16">

    {renderedProjects.map(({ data, Content }, index) => (
      <ProjectCard
        id={data.slug}
        number={data.number}
        title={data.title}
        role={data.role}
        location={data.location}
        years={data.years}
        sector={data.sector}
        founded={data.founded}
        meta={data.meta}
        videoPath={data.videoPath}
        videoTone={data.videoTone}
        isFirst={false}
        roleLabel="Role"
        sectorLabel="Sector"
      >
        <Content />
      </ProjectCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
