---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<BaseLayout
  title="Make — Matteo Martignoni"
  description="Twenty-five years of brand work in nine chapters, from Star Factory to NOVA."
  lang="en"
>
  <SectionHero
    number="02"
    tagline="The work, in chapters"
    title="Twenty-five years, nine chapters, four countries."
    intro="A chronological archive of the companies and brands I worked with — as employee, partner, or founder. Read in reverse: the most recent comes first, the oldest at the bottom."
  />

  <section class="max-w-3xl mt-16 md:mt-20">
    <p class="text-xs uppercase tracking-widest text-ink-500/70 mb-2">
      Coming next
    </p>
    <p class="text-ink-500 leading-relaxed">
      Nine project cards in chronological order, each with the city, the role, the years, and a short narrative. Building in the next iteration.
    </p>
  </section>

</BaseLayout>
