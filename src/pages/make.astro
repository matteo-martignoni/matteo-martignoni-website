---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter(item => item.data.lang === 'en')
  .sort((a, b) => a.data.order - b.data.order);

const renderedProjects = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await render(project);
    return { data: project.data, Content };
  })
);
---
<BaseLayout
  title="Make — Matteo Martignoni"
  description="Twenty-five years of brand work in ten chapters, across four countries."
  lang="en"
>
  <SectionHero
    number="02"
    tagline="The work, in chapters"
    title="Twenty-five years. Ten projects. Four countries."
    intro="Three of them I founded with head, heart, and hands together. The others I led for someone else's vision."
  />

  <section class="max-w-3xl mt-12 md:mt-16">

    {renderedProjects.map(({ data, Content }, index) => (
      <ProjectCard
        id={data.slug}
        number={data.number}
        title={data.title}
        role={data.role}
        location={data.location}
        years={data.years}
        sector={data.sector}
        founded={data.founded}
        meta={data.meta}
        videoPath={data.videoPath}
        videoTone={data.videoTone}
        isFirst={false}
        roleLabel="Role"
        sectorLabel="Sector"
      >
        <Content />
      </ProjectCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
