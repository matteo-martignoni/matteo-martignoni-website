---
import BaseLayout from '../layouts/BaseLayout.astro';

// Video catalogue — add entries here as more videos become available.
// Each entry has its own credit text in EN and IT.
const videos = [
  {
    src: '/morphe_web.mp4',
    credit_en: 'Morphē: the dystopian yet romantic take on lab-based creation by Lucy McRae.',
    credit_it: 'Morphē: la visione distopica e romantica di Lucy McRae sulla creazione in laboratorio.',
  },
  {
    src: '/XX^saint_louis_web.mp4',
    credit_en: 'Carefully designed light installation by Nonotak for Saint Louis.',
    credit_it: 'Installazione luminosa di Nonotak per Saint Louis.',
  },
];

const videosJson = JSON.stringify(videos);
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <!--
    ARCHITECTURE:
    Mobile  — flex-col: [text box top] [video wrap bottom]
    Desktop — block: video-wrap absolute aligned to "M", text in relative flow

    The .hero-video-wrap contains the video, the sage overlay, and the credit.
    This scopes the overlay and credit exclusively to the video area —
    no overlay bleed into the white text panel, no full-width shadow stripe.

    Rotation: localStorage counter advances by 1 on each page load,
    cycling through all videos sequentially. Works across tabs and sessions.
  -->

  <section slot="full-bleed" class="hero-section">

    <!-- VIDEO WRAP: relative + fixed height on mobile; absolute on desktop -->
    <div class="hero-video-wrap">

      <!-- Layer 1: video — src injected by rotation script -->
      <video
        id="hero-video"
        class="hero-video"
        autoplay loop muted playsinline preload="auto"
      ></video>

      <!-- Layer 2: sage overlay — scoped to video wrap only -->
      <div class="hero-overlay"></div>

      <!-- Credit: bottom-right of video area, no gradient, text-shadow -->
      <div class="hero-credit">
        <p id="hero-credit-text"></p>
      </div>

    </div>

    <!-- TEXT BOX: above video on mobile, relative flow on desktop -->
    <div class="hero-content">
      <div class="hero-text-box">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight"
            style="margin-bottom: 0.5rem;">
          Hand &amp; mind.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500" style="margin-bottom: 2.5rem;">
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>
      </div>
    </div>

  </section>

</BaseLayout>

<!-- Video rotation via localStorage: advances sequentially on every page load -->
<script define:vars={{ videosJson }}>
  (function () {
    const videos = JSON.parse(videosJson);
    const KEY = 'hero_video_index';

    // Read last shown index, advance by 1, wrap around
    let prev = parseInt(localStorage.getItem(KEY) ?? '-1', 10);
    if (isNaN(prev)) prev = -1;
    const idx = (prev + 1) % videos.length;
    localStorage.setItem(KEY, String(idx));

    const chosen = videos[idx];

    // Inject video source
    const videoEl = document.getElementById('hero-video');
    if (videoEl) {
      const source = document.createElement('source');
      source.src = chosen.src;
      source.type = 'video/mp4';
      videoEl.appendChild(source);
      videoEl.load();
      videoEl.play().catch(() => {});
    }

    // Inject EN credit
    const creditEl = document.getElementById('hero-credit-text');
    if (creditEl) creditEl.textContent = chosen.credit_en;
  })();
</script>

<style>
  /* ── MOBILE: text on top, video below ── */

  .hero-section {
    display: flex;
    flex-direction: column;
  }

  .hero-content {
    order: 1;
    padding: 3rem 2rem;
  }

  .hero-text-box {
    background: white;
    padding: 2rem;
  }

  /* Video wrap: relative block on mobile */
  .hero-video-wrap {
    order: 2;
    position: relative;
    width: 100%;
    height: 60vw;
    min-height: 240px;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Overlay: scoped to .hero-video-wrap — no full-page bleed */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
    pointer-events: none;
  }

  /* Hover reveal: only when cursor is over the video area */
  .hero-video-wrap:hover .hero-overlay {
    opacity: 0;
  }

  /* Credit: bottom-right of video wrap, no gradient, text-shadow for legibility */
  .hero-credit {
    position: absolute;
    bottom: 1rem;
    right: 1.25rem;
    text-align: right;
    max-width: 360px;
    z-index: 2;
    pointer-events: none;
  }

  .hero-credit p {
    font-size: 0.7rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }


  /* ── DESKTOP (md+): absolute video wrap aligned to "M" ── */

  @media (min-width: 768px) {

    .hero-section {
      display: block;
      position: relative;
      min-height: 74vh;
      overflow: hidden;
    }

    /* Video wrap: absolute, left edge aligned with "M" in header */
    .hero-video-wrap {
      position: absolute;
      top: 0;
      bottom: 0;
      right: 0;
      /* px-12 (3rem) + MM mark (35px) + gap-3 (0.75rem) = ~95px */
      left: calc(3rem + 35px + 0.75rem);
      width: auto;
      height: auto;
      order: 0;
    }

    .hero-video {
      object-position: left center;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      min-height: 74vh;
      padding: 3rem 4rem;
      order: 0;
      pointer-events: none; /* passes hover through to video wrap */
    }

    .hero-text-box {
      padding: 3rem 3.5rem;
      max-width: 480px;
      pointer-events: auto; /* text remains selectable */
    }

    .hero-credit {
      bottom: 1.25rem;
      right: 1.5rem;
    }

    .hero-credit p {
      font-size: 0.75rem;
    }
  }
</style>
