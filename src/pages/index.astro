---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <section
    slot="full-bleed"
    class="hero-section"
    style="position: relative; min-height: 74vh; overflow: hidden;"
  >

    <!--
      LAYER 1: video — independent, anchored to left.
      Left edge aligns with the "M" of Matteo Martignoni in the header:
        mobile:  px-8 (2rem) + mark (35px) + gap-3 (0.75rem)  = ~79px
        desktop: px-12 (3rem) + mark (35px) + gap-3 (0.75rem) = ~95px
      CSS class .hero-video handles responsive left via media query.
    -->
    <video
      class="hero-video"
      autoplay loop muted playsinline preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <!-- Sage overlay — sits on the video, fades on hover -->
    <div
      class="hero-overlay"
      style="position: absolute; inset: 0; z-index: 1; pointer-events: none;"
    ></div>

    <!-- LAYERS 2 + 3: relative flow, vertically centered -->
    <div
      style="
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        min-height: 74vh;
        padding: 3rem 4rem;
      "
    >
      <!-- LAYER 2: white box — dimensions driven by content -->
      <div style="background: white; padding: 3rem 3.5rem; max-width: 480px;">

        <!-- LAYER 3: text -->
        <h1
          class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight"
          style="margin-bottom: 0.5rem;"
        >
          Hand &amp; mind.
        </h1>
        <p
          class="text-2xl md:text-3xl text-ink-500"
          style="margin-bottom: 2.5rem;"
        >
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>

      </div>
    </div>

    <!-- Credit strip -->
    <div
      class="hero-credit"
      style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 3; padding: 2.5rem 4rem 1.25rem;"
    >
      <p style="font-size: 0.75rem; color: rgba(255,255,255,0.7); line-height: 1.6;">
        Morphē is a video created by Lucy McRae for Aēsop.
        A dystopian yet romantic take on lab-based creation.
      </p>
    </div>

  </section>

</BaseLayout>

<style>
  /* LAYER 1: video — left edge aligned with "M" of Matteo Martignoni */
  .hero-video {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    /* mobile: px-8 (2rem) + mark (35px) + gap-3 (0.75rem) */
    left: calc(2rem + 35px + 0.75rem);
    height: 100%;
    object-fit: cover;
    object-position: left center;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .hero-video {
      /* desktop: px-12 (3rem) + mark (35px) + gap-3 (0.75rem) */
      left: calc(3rem + 35px + 0.75rem);
    }
  }

  /* Sage overlay: full strength, fades on hover */
  .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }

  /* Credit strip gradient */
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.50) 0%,
      rgba(0, 0, 0, 0.08) 60%,
      transparent 100%
    );
  }
</style>
