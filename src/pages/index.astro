---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand development. Italy and abroad."
  description="Twenty-five years working with brands across Europe, Asia and the Americas."
  lang="en"
>
  <main class="min-h-screen px-8 py-16 md:px-16 md:py-24 max-w-3xl">

    <p class="text-xs uppercase tracking-widest text-terracotta-900 mb-6">
      Workshop · setup in progress
    </p>

    <h1 class="text-4xl md:text-5xl font-medium text-ink-900 mb-3">
      Matteo Martignoni
    </h1>

    <p class="text-lg text-ink-500 mb-12">
      Brand development. Italy and abroad.
    </p>

    <div class="w-10 h-px bg-sage-100 mb-12"></div>

    <p class="text-ink-700 leading-relaxed">
      This is iteration 01 — the foundation. If you are reading this online,
      the build pipeline works: code lives in GitHub, Cloudflare Pages builds
      it on every change, and visitors anywhere in the world receive the
      result through a global CDN. The site itself is coming together,
      section by section.
    </p>

    <nav class="mt-16">
      <a
        href="/it/"
        class="text-sm text-sage-900 underline underline-offset-4 hover:text-terracotta-900 transition-colors duration-200"
      >
        Versione italiana →
      </a>
    </nav>

  </main>
</BaseLayout>
