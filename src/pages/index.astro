---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <!-- Hero: full-width video behind, white text panel floating on left -->
  <section class="hero-section relative overflow-hidden -mx-8 md:-mx-12" style="min-height: 72vh;">

    <!-- Video — absolute, fills the entire section -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay loop muted playsinline preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <!-- Sage overlay — full width, fades on hover to reveal original colours -->
    <div class="hero-overlay absolute inset-0 z-10 pointer-events-none"></div>

    <!-- Layout layer: white panel left + transparent video area right -->
    <div class="relative z-20 flex flex-col md:flex-row" style="min-height: 72vh;">

      <!-- White text panel — covers left 42% on desktop, full width on mobile -->
      <div class="bg-white flex items-center w-full md:w-5/12 shrink-0 py-14 md:py-0 px-8 md:px-12 lg:px-14">
        <div>
          <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-2">
            Hand &amp; mind.
          </h1>
          <p class="text-2xl md:text-3xl text-ink-500 mb-10">
            Workshop of brands.
          </p>
          <p class="text-sm text-ink-700 leading-relaxed max-w-xs">
            Twenty-five years building and repositioning brands across
            fashion, beauty, culture, and technology.
            Italy-based, internationally active.
          </p>
        </div>
      </div>

      <!-- Video area — transparent, lets video + overlay show through -->
      <div class="flex-1 relative min-h-[55vw] md:min-h-0">

        <!-- Credit strip — anchored to bottom of video area -->
        <div class="absolute bottom-0 left-0 right-0 hero-credit px-5 pt-8 pb-4 pointer-events-none">
          <p class="text-xs text-white/75 leading-relaxed">
            Morphē is a video created by Lucy McRae for Aēsop.
            A dystopian yet romantic take on lab-based creation.
          </p>
        </div>

      </div>

    </div>

  </section>

</BaseLayout>

<style>
  /* Sage overlay: full strength by default */
  .hero-section .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }

  /* Hover anywhere on section fades the overlay on the video side */
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }

  /* Credit strip: gradient from dark at bottom to transparent */
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.1) 65%,
      transparent 100%
    );
  }
</style>
