---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <!--
    The hero section uses slot="full-bleed" to render OUTSIDE the padded main.
    It becomes a direct child of <body>, so it is truly full-viewport-width
    with no padding, max-width, or overflow constraints from any parent.
    The white text panel is positioned absolute over the left 40%.
    The video fills the full section behind everything.
  -->
  <section
    slot="full-bleed"
    class="hero-section relative overflow-hidden"
    style="min-height: 74vh;"
  >

    <!-- Video: covers the full section from edge to edge -->
    <video
      class="absolute inset-0 w-full h-full object-cover object-center"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <!-- Sage overlay: full width, fades on hover to reveal original colours -->
    <div class="hero-overlay absolute inset-0 z-10 pointer-events-none"></div>

    <!-- White text panel: absolute over left 40% of the full-width section -->
    <div
      class="absolute inset-y-0 left-0 z-20 bg-white flex items-center"
      style="width: 40%;"
    >
      <div class="px-8 md:px-12 lg:px-16 max-w-md">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-2">
          Hand &amp; mind.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500 mb-10">
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>
      </div>
    </div>

    <!-- Credit strip: anchored to bottom of the video area (right 60%) -->
    <div
      class="absolute bottom-0 z-20 hero-credit px-6 pt-10 pb-4 pointer-events-none"
      style="left: 40%; right: 0;"
    >
      <p class="text-xs text-white/75 leading-relaxed">
        Morphē: a dystopian yet romantic take on lab-based creation by Lucy McRae.
      </p>
    </div>

  </section>

</BaseLayout>

<style>
  .hero-section .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.1) 65%,
      transparent 100%
    );
  }
</style>
