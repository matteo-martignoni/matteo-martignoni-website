---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand development. Italy and abroad."
  description="Twenty-five years working with brands across Europe, Asia and the Americas."
  lang="en"
>
  <section class="max-w-3xl py-8 md:py-12">

    <p class="text-xs uppercase tracking-widest text-terracotta-900 mb-6">
      Iteration 02 · the layout
    </p>

    <h2 class="text-3xl md:text-4xl font-medium text-ink-900 leading-tight mb-6">
      Twenty-five years working with brands across Europe, Asia and the Americas.
    </h2>

    <div class="w-10 h-px bg-sage-100 mb-8" aria-hidden="true"></div>

    <p class="text-ink-700 leading-relaxed mb-4">
      Diesel, Eastpak, Surface to Air, Aēsop, Reflex. Today I run a strategic
      agency office in Milan and co-founded NOVA, an AI experience company.
    </p>

    <p class="text-ink-700 leading-relaxed">
      I take on brand projects as a senior partner — close to the product,
      close to the people.
    </p>

  </section>
</BaseLayout>
