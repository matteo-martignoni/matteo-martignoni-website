---
import BaseLayout from '../layouts/BaseLayout.astro';

// Video catalogue — add new entries here as more videos become available.
// credit_en and credit_it are displayed at the bottom of the video area.
const videos = [
  {
    src: '/morphe_web.mp4',
    credit_en: 'Morphē: the dystopian yet romantic take on lab-based creation by Lucy McRae.',
    credit_it: 'Morphē: la visione distopica e romantica di Lucy McRae sulla creazione in laboratorio.',
  },
  {
    src: '/saint_louis_web.mp4',
    credit_en: 'Saint Louis exhibition at MDW, Church of Carmine.',
    credit_it: 'Esposizione Saint Louis durante il Salone del Mobile, Chiesa del Carmine.',
  },
];

// Serialise the video list for the client-side rotation script.
const videosJson = JSON.stringify(videos);
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <section
    slot="full-bleed"
    class="hero-section"
    style="position: relative; min-height: 74vh; overflow: hidden;"
  >

    <!-- LAYER 1: video — set by JavaScript from sessionStorage rotation -->
    <!-- The video element starts empty; the inline script below fills it -->
    <video
      id="hero-video"
      class="hero-video"
      autoplay loop muted playsinline preload="auto"
    >
      <!-- <source> injected by rotation script -->
    </video>

    <!-- Sage overlay — fades on hover -->
    <div class="hero-overlay absolute inset-0 z-10 pointer-events-none"></div>

    <!-- LAYERS 2 + 3: white box over left side -->
    <div
      style="position: relative; z-index: 2; display: flex; align-items: center; min-height: 74vh; padding: 3rem 4rem;"
    >
      <div style="background: white; padding: 3rem 3.5rem; max-width: 480px;">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight" style="margin-bottom: 0.5rem;">
          Hand &amp; mind.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500" style="margin-bottom: 2.5rem;">
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>
      </div>
    </div>

    <!-- Credit strip — text injected by rotation script -->
    <div
      id="hero-credit"
      class="hero-credit"
      style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 3; padding: 2.5rem 4rem 1.25rem;"
    >
      <p id="hero-credit-text" style="font-size: 0.75rem; color: rgba(255,255,255,0.7); line-height: 1.6; text-align: right;"></p>
    </div>

  </section>

</BaseLayout>

<!-- Video rotation: pick a random video once per browser session -->
<script define:vars={{ videosJson }}>
  (function () {
    const videos = JSON.parse(videosJson);
    const KEY = 'hero_video_index';

    // Read from sessionStorage — same video for the whole session
    let idx = sessionStorage.getItem(KEY);
    if (idx === null || isNaN(Number(idx))) {
      idx = Math.floor(Math.random() * videos.length);
      sessionStorage.setItem(KEY, String(idx));
    } else {
      idx = Number(idx);
      // Advance to the next video on subsequent sessions
      // (sessionStorage is per tab; this ensures variety across new tabs)
    }

    const chosen = videos[idx % videos.length];

    // Inject <source> into the video element
    const videoEl = document.getElementById('hero-video');
    if (videoEl) {
      const source = document.createElement('source');
      source.src = chosen.src;
      source.type = 'video/mp4';
      videoEl.appendChild(source);
      videoEl.load();
      videoEl.play().catch(() => {});
    }

    // Inject credit text (EN version)
    const creditEl = document.getElementById('hero-credit-text');
    if (creditEl) {
      creditEl.textContent = chosen.credit_en;
    }
  })();
</script>

<style>
  .hero-video {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    left: calc(2rem + 35px + 0.75rem);
    height: 100%;
    object-fit: cover;
    object-position: left center;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .hero-video {
      left: calc(3rem + 35px + 0.75rem);
    }
  }
  .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.50) 0%,
      rgba(0, 0, 0, 0.08) 60%,
      transparent 100%
    );
  }
</style>
