---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <!--
    STRUCTURE:
    Mobile  — flex-col: [text box on top] [video below]
    Desktop — block: video-wrap is absolute (left aligned to "M"), text box floats in normal flow

    hero-video-wrap contains video + overlay + credit so:
    - overlay covers ONLY the video, not the full page
    - credit is anchored inside the video area
    - hover effect is scoped to the video area only
  -->
  <section slot="full-bleed" class="hero-section">

    <!-- VIDEO WRAP: relative on mobile (60vw tall), absolute on desktop -->
    <div class="hero-video-wrap">

      <!-- Layer 1: video -->
      <video
        class="hero-video"
        autoplay loop muted playsinline preload="auto"
      >
        <source src="/morphe_web.mp4" type="video/mp4" />
      </video>

      <!-- Layer 2: sage overlay — scoped to video area only -->
      <div class="hero-overlay"></div>

      <!-- Credit: right-aligned, bottom of video area, no gradient -->
      <div class="hero-credit">
        <p>
          Morphē: the dystopian yet romantic take on lab-based creation by Lucy McRae.
        </p>
      </div>

    </div>

    <!-- TEXT BOX: on top on mobile, floats left on desktop -->
    <div class="hero-content">
      <div class="hero-text-box">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight" style="margin-bottom:0.5rem">
          Hand &amp; mind.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500" style="margin-bottom:2.5rem">
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>
      </div>
    </div>

  </section>

</BaseLayout>

<style>
  /* ── MOBILE: stacked (text top, video bottom) ── */

  .hero-section {
    display: flex;
    flex-direction: column;
  }

  /* Text box: first in the stack */
  .hero-content {
    order: 1;
    padding: 3rem 2rem;
  }
  .hero-text-box {
    background: white;
    padding: 2rem 2rem;
  }

  /* Video wrap: second in the stack, relative so overlay works inside it */
  .hero-video-wrap {
    order: 2;
    position: relative;
    width: 100%;
    height: 60vw;
    overflow: hidden;
    min-height: 240px;
  }

  /* Video fills the wrap */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Overlay: covers only the video-wrap */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
    pointer-events: none;
  }

  /* Hover reveal: only when cursor is over the video */
  .hero-video-wrap:hover .hero-overlay {
    opacity: 0;
  }

  /* Credit: right-aligned, no gradient, subtle text shadow for legibility */
  .hero-credit {
    position: absolute;
    bottom: 1rem;
    right: 1.25rem;
    text-align: right;
    max-width: 360px;
    z-index: 2;
    pointer-events: none;
  }
  .hero-credit p {
    font-size: 0.7rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
  }


  /* ── DESKTOP (md+): absolute video, text floats left ── */

  @media (min-width: 768px) {

    .hero-section {
      display: block;
      position: relative;
      min-height: 74vh;
      overflow: hidden;
    }

    .hero-video-wrap {
      position: absolute;
      top: 0;
      bottom: 0;
      right: 0;
      left: calc(3rem + 35px + 0.75rem);
      width: auto;
      height: auto;
      order: 0;
    }

    .hero-video {
      object-position: left center;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      min-height: 74vh;
      padding: 3rem 4rem;
      order: 0;
      pointer-events: none;
    }

    .hero-text-box {
      padding: 3rem 3.5rem;
      max-width: 480px;
      pointer-events: auto;
    }

    .hero-credit {
      bottom: 1.25rem;
      right: 1.5rem;
    }

    .hero-credit p {
      font-size: 0.75rem;
    }

  }
</style>
