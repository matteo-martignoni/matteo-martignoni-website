---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand development. Italy and abroad."
  description="Twenty-five years working with brands across Europe, Asia and the Americas. Diesel, Eastpak, Surface to Air, Aēsop, Reflex."
  lang="en"
>
  <section class="max-w-3xl py-8 md:py-12">

    <p class="text-xs uppercase tracking-widest text-terracotta-900 mb-8">
      Introduction
    </p>

    <h2 class="text-3xl md:text-4xl font-medium text-ink-900 leading-tight mb-8">
      Twenty-five years working with brands across Europe, Asia and the Americas.
    </h2>

    <div class="flex items-center gap-3 mb-8" aria-hidden="true">
      <div class="w-10 h-px bg-sage-100"></div>
    </div>

    <div class="space-y-5 text-ink-700 leading-relaxed mb-12">
      <p>
        Diesel, Eastpak, Surface to Air, Aēsop, Reflex. Today I run the Milan
        office of a strategic agency, and I co-founded NOVA — an AI experience
        company opening its first exhibition in 2025.
      </p>
      <p>
        I take on brand projects as a senior partner — close to the product,
        close to the people. New categories, retail, licensing, repositioning.
        Work that needs both judgement and hands.
      </p>
    </div>

    <a
      href="/make"
      class="inline-flex items-center gap-3 text-xs uppercase tracking-widest text-terracotta-900 hover:text-terracotta-700 transition-colors duration-200 group"
    >
      <span class="group-hover:underline underline-offset-4">Enter the workshop</span>
      <span class="inline-block transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
    </a>

  </section>

  <section class="max-w-5xl mt-20 md:mt-28">
    <MediaPlaceholder
      chapter="Chapter 01 — Aēsop Italy, 2015"
      aspectRatio="16/10"
    />
  </section>

</BaseLayout>
