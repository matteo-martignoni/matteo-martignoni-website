---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Brand Strategist"
  description="Hand & mind. Workshop of brands. Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology."
  lang="en"
>

  <!--
    Hero: true full-viewport-width section.
    The `margin-left: calc(-50vw + 50%)` trick breaks out of ANY parent
    padding or max-width constraint — the only reliable full-bleed technique.
    Video fills the entire section behind everything.
    White text panel floats on the left with z-index above video + overlay.
  -->
  <section
    class="hero-section relative overflow-hidden"
    style="
      min-height: 74vh;
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);
    "
  >

    <!-- Video: covers the full section, anchored center -->
    <video
      class="absolute inset-0 w-full h-full object-cover object-left"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <!-- Sage overlay: full width, fades on hover -->
    <div class="hero-overlay absolute inset-0 z-10 pointer-events-none"></div>

    <!-- White text panel: absolute left, full height, 40% wide -->
    <div
      class="absolute inset-y-0 left-0 z-20 bg-white flex items-center"
      style="width: 40%;"
    >
      <div class="px-12 md:px-16 lg:px-20 max-w-md">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-2">
          Hand &amp; mind.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500 mb-10">
          Workshop of brands.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Twenty-five years building and repositioning brands across
          fashion, beauty, culture, and technology.
          Italy-based, internationally active.
        </p>
      </div>
    </div>

    <!-- Credit strip: bottom of the video area (right 60%) -->
    <div
      class="absolute bottom-0 z-20 hero-credit px-6 pt-10 pb-4 pointer-events-none"
      style="left: 40%; right: 0;"
    >
      <p class="text-xs text-white/75 leading-relaxed">
        Morphē is a video created by Lucy McRae for Aēsop.
        A dystopian yet romantic take on lab-based creation.
      </p>
    </div>

  </section>

</BaseLayout>

<style>
  /* Sage overlay: full strength, fades on hover anywhere in the section */
  .hero-section .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }

  /* Credit gradient: dark at bottom, fades to transparent */
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.1) 65%,
      transparent 100%
    );
  }
</style>
