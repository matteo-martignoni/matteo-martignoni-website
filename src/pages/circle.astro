---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<BaseLayout
  title="Circle — Matteo Martignoni"
  description="Four mentors who shaped how I see brand work: Dennis Paphitis, Jeremy Rozan, Renzo Rosso, Luca Sacchetti."
  lang="en"
>
  <SectionHero
    number="03"
    tagline="Maestri"
    title="Four people who shaped how I see this work."
    intro="Every practice is built with help. Four mentors taught me distinct things: ethics and patience, taste and ease, scale from nothing, the discipline of method. Each is worth a sentence."
  />

  <section class="max-w-3xl mt-16 md:mt-20">
    <p class="text-xs uppercase tracking-widest text-ink-500/70 mb-2">
      Coming next
    </p>
    <p class="text-ink-500 leading-relaxed">
      The four names. Each with their role, the lesson, and a link to the project we worked on together where applicable. Building in the next iteration.
    </p>
  </section>

</BaseLayout>
