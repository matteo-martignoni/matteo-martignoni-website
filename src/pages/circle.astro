---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
import MaestroCard from '../components/MaestroCard.astro';

const allMentors = await getCollection('mentors');
const mentors = allMentors
  .filter(item => item.data.lang === 'en')
  .sort((a, b) => a.data.order - b.data.order);

const renderedMentors = await Promise.all(
  mentors.map(async (mentor) => {
    const { Content } = await render(mentor);
    return { data: mentor.data, Content };
  })
);
---
<BaseLayout
  title="Mentors & Influences — Matteo Martignoni"
  description="Mentors who shaped how I see brand work: Dennis Paphitis, Renzo Rosso, Luca Sacchetti."
  lang="en"
>
  <SectionHero
    number="03"
    tagline="Maestri"
    title="People who shaped how I see this work."
    intro="From the very first day of my working life I have been lucky to meet people of enormous talent, character, and style. But few have truly marked my life like these."
    quote="“A lot of people have gone further than they thought they could because someone else thought they could.”"
    quoteAuthor="Zig Ziglar"
  />

  <!-- Tinted background section — warm white #F4F1EA signals a change of register -->
  <section class="max-w-3xl mt-12 md:mt-16 bg-warm-100 -mx-8 md:-mx-12 px-8 md:px-12 pt-2 pb-6">

    {renderedMentors.map(({ data, Content }, index) => (
      <MaestroCard
        name={data.name}
        role={data.role}
        portrait={data.portrait}
        projectHref={data.projectSlug ? `/make#${data.projectSlug}` : undefined}
        projectLabel={data.projectLabel}
        linkPrefix="A project we worked on"
        isFirst={false}
        portraitMobileBoost={data.slug === 'dennis-paphitis' || data.slug === 'renzo-rosso'}
        portraitShrink={data.slug === 'luca-sacchetti'}
      >
        <Content />
      </MaestroCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
