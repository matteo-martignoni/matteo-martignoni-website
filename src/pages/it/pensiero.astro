---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import CompetencyAccordion from '../../components/CompetencyAccordion.astro';

// Load all IT competencies, sorted by order field (01 through 06)
const allCompetencies = await getCollection('competencies');
const competencies = allCompetencies
  .filter(item => item.data.lang === 'it')
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Pensiero — Matteo Martignoni"
  description="Sei aree di pratica nello sviluppo di marchi: espansione internazionale, nuove categorie, licenze, retail, marketing, riposizionamento."
  lang="it"
>
  <SectionHero
    number="01"
    tagline="Aree di pratica"
    title="Sei cose che so fare."
    intro="Venticinque anni distillati in sei pratiche tra loro collegate. Sono lenti utili per leggere un problema di marca. La maggior parte dei progetti ne tocca tre o quattro insieme."
  />

  <section class="max-w-3xl mt-12 md:mt-16">

    {competencies.map((item, index) => (
      <CompetencyAccordion
        number={item.data.number}
        title={item.data.title}
        description={item.data.description}
        examples={item.data.examples}
        isFirst={false}
      />
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
