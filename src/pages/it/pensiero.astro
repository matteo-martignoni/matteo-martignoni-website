---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ThinkPractices from '../../components/ThinkPractices.astro';
import { thinkHero } from '../../data/think';

const hero = thinkHero.it;
---
<BaseLayout
  title="Strategia di marca e riposizionamento — Matteo Martignoni"
  description="Lavoro sui marchi dall'inizio alla fine: sviluppo internazionale, nuove categorie, licensing, strategia retail, marketing, riposizionamento, eventi."
  lang="it"
>
  <SectionHero
    number="01"
    tagline={hero.tagline}
    title={hero.title}
    intro={hero.lead}
  />

  <section class="max-w-3xl">
    <p class="text-ink-700 leading-relaxed">{hero.body}</p>

    <div class="mt-10 md:mt-14">
      <ThinkPractices lang="it" />
    </div>
  </section>
</BaseLayout>
