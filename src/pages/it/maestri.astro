---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import MaestroCard from '../../components/MaestroCard.astro';

const allMentors = await getCollection('mentors');
const mentors = allMentors
  .filter(item => item.data.lang === 'it')
  .sort((a, b) => a.data.order - b.data.order);

const renderedMentors = await Promise.all(
  mentors.map(async (mentor) => {
    const { Content } = await render(mentor);
    return { data: mentor.data, Content };
  })
);
---
<BaseLayout
  title="Maestri e influenze — Matteo Martignoni"
  description="Maestri che hanno formato il mio sguardo: Dennis Paphitis, Renzo Rosso, Luca Sacchetti."
  lang="it"
>
  <SectionHero
    number="03"
    tagline="Maestri"
    title="Persone che hanno formato il mio sguardo su questo mestiere."
    intro="Dal primo giorno della mia vita lavorativa ho avuto la fortuna di conoscere persone di enorme talento, carattere e stile. Ma poche hanno davvero segnato la mia vita come queste."
    quote="“Molte persone sono andate oltre i propri limiti perché qualcun altro credeva che potessero farcela.”"
    quoteAuthor="Zig Ziglar"
  />

  <section class="max-w-3xl mt-12 md:mt-16 bg-warm-100 -mx-8 md:-mx-12 px-8 md:px-12 pt-2 pb-6">

    {renderedMentors.map(({ data, Content }, index) => (
      <MaestroCard
        name={data.name}
        role={data.role}
        portrait={data.portrait}
        projectHref={data.projectSlug ? `/it/manualita#${data.projectSlug}` : undefined}
        projectLabel={data.projectLabel}
        linkPrefix="Un progetto su cui abbiamo lavorato"
        isFirst={false}
      >
        <Content />
      </MaestroCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
