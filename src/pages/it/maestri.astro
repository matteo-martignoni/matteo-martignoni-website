---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import MaestroCard from '../../components/MaestroCard.astro';

const allMentors = await getCollection('mentors');
const mentors = allMentors
  .filter(item => item.data.lang === 'it')
  .sort((a, b) => a.data.order - b.data.order);

const renderedMentors = await Promise.all(
  mentors.map(async (mentor) => {
    const { Content } = await render(mentor);
    return { data: mentor.data, Content };
  })
);
---
<BaseLayout
  title="Maestri — Matteo Martignoni"
  description="Tre maestri che hanno formato il mio sguardo: Dennis Paphitis, Renzo Rosso, Luca Sacchetti."
  lang="it"
>
  <SectionHero
    number="03"
    tagline="Maestri"
    title="Tre persone che hanno formato il mio sguardo su questo mestiere."
    intro="Ogni mestiere si costruisce con un aiuto. Tre maestri mi hanno insegnato cose distinte: etica e pazienza, scala dal niente, la disciplina del metodo. Ognuno merita una frase."
  />

  <section class="max-w-3xl mt-12 md:mt-16 bg-warm-100 -mx-8 md:-mx-12 px-8 md:px-12 pt-2 pb-6">

    {renderedMentors.map(({ data, Content }, index) => (
      <MaestroCard
        name={data.name}
        role={data.role}
        portrait={data.portrait}
        projectHref={data.projectSlug ? `/it/manualita#${data.projectSlug}` : undefined}
        projectLabel={data.projectLabel}
        linkPrefix="Un progetto su cui abbiamo lavorato"
        isFirst={false}
        portraitMobileBoost={data.slug === 'dennis-paphitis' || data.slug === 'renzo-rosso'}
      >
        <Content />
      </MaestroCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
