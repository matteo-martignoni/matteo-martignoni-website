---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Stratega di marca"
  description="Testa e mani. La bottega dei marchi. Venticinque anni a costruire e riposizionare marchi nella moda, bellezza, cultura e tecnologia."
  lang="it"
>

  <section
    slot="full-bleed"
    class="hero-section relative overflow-hidden"
    style="min-height: 74vh;"
  >

    <video
      class="absolute inset-0 w-full h-full object-cover object-center"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <div class="hero-overlay absolute inset-0 z-10 pointer-events-none"></div>

    <div
      class="absolute inset-y-0 left-0 z-20 bg-white flex items-center"
      style="width: 40%;"
    >
      <div class="px-8 md:px-12 lg:px-16 max-w-md">
        <h1 class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight mb-2">
          Testa e mani.
        </h1>
        <p class="text-2xl md:text-3xl text-ink-500 mb-10">
          La bottega dei marchi.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Venticinque anni a costruire e riposizionare marchi nella moda,
          bellezza, cultura e tecnologia.
          Basato in Italia, attivo a livello internazionale.
        </p>
      </div>
    </div>

    <div
      class="absolute bottom-0 z-20 hero-credit px-6 pt-10 pb-4 pointer-events-none"
      style="left: 40%; right: 0;"
    >
      <p class="text-xs text-white/75 leading-relaxed">
        Morphē è un video creato da Lucy McRae per Aēsop.
        Una visione distopica ma romantica sulla creazione in laboratorio.
      </p>
    </div>

  </section>

</BaseLayout>

<style>
  .hero-section .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.1) 65%,
      transparent 100%
    );
  }
</style>
