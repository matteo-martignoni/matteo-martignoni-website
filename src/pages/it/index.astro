---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Matteo Martignoni — Stratega di marca"
  description="Testa e mani. La bottega dei marchi. Venticinque anni a costruire e riposizionare marchi nella moda, bellezza, cultura e tecnologia."
  lang="it"
>

  <section
    slot="full-bleed"
    class="hero-section"
    style="position: relative; min-height: 74vh; overflow: hidden;"
  >

    <video
      class="hero-video"
      autoplay loop muted playsinline preload="auto"
    >
      <source src="/morphe_web.mp4" type="video/mp4" />
    </video>

    <div
      class="hero-overlay"
      style="position: absolute; inset: 0; z-index: 1; pointer-events: none;"
    ></div>

    <div
      style="
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        min-height: 74vh;
        padding: 3rem 4rem;
      "
    >
      <div style="background: white; padding: 3rem 3.5rem; max-width: 480px;">

        <h1
          class="text-4xl md:text-5xl font-medium text-ink-900 leading-tight"
          style="margin-bottom: 0.5rem;"
        >
          Testa e mani.
        </h1>
        <p
          class="text-2xl md:text-3xl text-ink-500"
          style="margin-bottom: 2.5rem;"
        >
          La bottega dei marchi.
        </p>
        <p class="text-sm text-ink-700 leading-relaxed">
          Venticinque anni a costruire e riposizionare marchi nella moda,
          bellezza, cultura e tecnologia.
          Basato in Italia, attivo a livello internazionale.
        </p>

      </div>
    </div>

    <div
      class="hero-credit"
      style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 3; padding: 2.5rem 4rem 1.25rem;"
    >
      <p style="font-size: 0.75rem; color: rgba(255,255,255,0.7); line-height: 1.6;">
        Morphē è un video creato da Lucy McRae per Aēsop.
        Una visione distopica ma romantica sulla creazione in laboratorio.
      </p>
    </div>

  </section>

</BaseLayout>

<style>
  .hero-video {
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    left: calc(2rem + 35px + 0.75rem);
    height: 100%;
    object-fit: cover;
    object-position: left center;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .hero-video {
      left: calc(3rem + 35px + 0.75rem);
    }
  }
  .hero-overlay {
    background-color: rgba(168, 212, 188, 0.75);
    opacity: 1;
    transition: opacity 600ms ease;
  }
  .hero-section:hover .hero-overlay {
    opacity: 0;
  }
  .hero-credit {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.50) 0%,
      rgba(0, 0, 0, 0.08) 60%,
      transparent 100%
    );
  }
</style>
