---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter(item => item.data.lang === 'it')
  .sort((a, b) => a.data.order - b.data.order);

const renderedProjects = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await render(project);
    return { data: project.data, Content };
  })
);
---
<BaseLayout
  title="Manualità — Matteo Martignoni"
  description="Venticinque anni di lavoro con i marchi in dieci capitoli, in quattro paesi."
  lang="it"
>
  <SectionHero
    number="02"
    tagline="Il lavoro, in capitoli"
    title="Venticinque anni. Dieci progetti. Quattro paesi."
    intro="Tre di loro sono nati anche col mio cuore, oltre che con la mia testa e le mie mani. Gli altri li ho diretti per la visione di qualcun altro."
  />

  <section class="max-w-3xl mt-12 md:mt-16">

    {renderedProjects.map(({ data, Content }, index) => (
      <ProjectCard
        number={data.number}
        title={data.title}
        role={data.role}
        location={data.location}
        years={data.years}
        sector={data.sector}
        founded={data.founded}
        meta={data.meta}
        isFirst={index === 0}
        roleLabel="Ruolo"
        sectorLabel="Settore"
      >
        <Content />
      </ProjectCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
