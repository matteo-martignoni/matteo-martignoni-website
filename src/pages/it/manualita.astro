---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter(item => item.data.lang === 'it')
  .sort((a, b) => a.data.order - b.data.order);

const renderedProjects = await Promise.all(
  projects.map(async (project) => {
    const { Content } = await render(project);
    return { data: project.data, Content };
  })
);
---
<BaseLayout
  title="Progetti di marca: Diesel, Aēsop, Uniqlo — Matteo Martignoni"
  description="Venticinque anni di lavoro con i marchi in dieci capitoli, in quattro paesi."
  lang="it"
>
  <SectionHero
    number="02"
    tagline="Il lavoro, in capitoli"
    title="Venticinque anni di esperienza tra confini, marchi e culture."
    intro="Tre di questi li ho fondati con la mia testa, il mio cuore e le mie mani. Gli altri li ho supportati sulla base della visione di qualcun altro."
  />

  <section class="max-w-3xl mt-12 md:mt-16">

    {renderedProjects.map(({ data, Content }, index) => (
      <ProjectCard
        id={data.slug}
        number={data.number}
        title={data.title}
        role={data.role}
        location={data.location}
        years={data.years}
        sector={data.sector}
        founded={data.founded}
        meta={data.meta}
        videoPath={data.videoPath}
        videoTone={data.videoTone}
        isFirst={false}
        roleLabel="Ruolo"
        sectorLabel="Settore"
      >
        <Content />
      </ProjectCard>
    ))}

    <div class="border-b border-warm-200" aria-hidden="true"></div>

  </section>

</BaseLayout>
