---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHero from '../components/SectionHero.astro';
---
<BaseLayout
  title="Visit — Matteo Martignoni"
  description="Two ways to start a brand project — direct contact for executives, through Reflex Group for international agencies."
  lang="en"
>
  <SectionHero
    number="04"
    tagline="Two ways to enter the workshop"
    title="Direct, or through Reflex."
    intro="Brand projects come to me through two channels: directly, for executives building or repositioning a brand, and through Reflex Group, where I run the Milan office for international agencies needing a senior partner on the ground in Italy."
  />

  <section class="max-w-3xl mt-16 md:mt-20">
    <p class="text-xs uppercase tracking-widest text-ink-500/70 mb-2">
      Coming next
    </p>
    <p class="text-ink-500 leading-relaxed">
      The two contact cards, the bilingual untranslatable note, and the direct contact details. Building in the next iteration.
    </p>
  </section>

</BaseLayout>
