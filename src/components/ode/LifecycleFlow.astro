---
// LifecycleFlow — the central traceability infographic.
// The life of a Parmigiano Reggiano dairy cow from birth to slaughter, the
// regulatory layer that documents each stage, the grey area where individual
// identity dissolves into a rendering lot, and the point where OdE plugs in.
// Content anchored to the knowledge base (DOP traceability research).
import CowGlyph from './CowGlyph.astro';

interface Props {
  lang?: 'it' | 'en';
}
const { lang = 'it' } = Astro.props;

type Norm = 'cogente' | 'disciplinare' | 'generale';
type Trace = 'strong' | 'weak' | 'lot';

const content = {
  it: {
    normLabel: { cogente: 'Norma cogente', disciplinare: 'Disciplinare DOP', generale: 'Norma generale' } as Record<Norm, string>,
    greyBracket: 'Area grigia: dalla movimentazione al lotto, l’identità individuale si indebolisce e poi si dissolve',
    odeBracket: 'OdE ri-lega l’origine: catena di custodia · Passaporto Lipidico Digitale · AMSA',
    scrollHint: 'Scorri in orizzontale per seguire il percorso →',
    legend: [
      { k: 'strong', t: 'Tracciabilità individuale cogente (anagrafe BDN)' },
      { k: 'grey', t: 'Area grigia: identità che si dissolve nel lotto' },
      { k: 'ode', t: 'Intervento OdE: il vuoto colmato' },
    ],
    stages: [
      { glyph: 'calf', time: 'Giorno 0', title: 'Nascita', norm: 'cogente', trace: 'strong', note: 'Il vitello nasce nella stalla del comprensorio DOP.' },
      { glyph: null, time: 'Entro 20 giorni', title: 'Identificazione', norm: 'cogente', trace: 'strong', note: 'Doppia marca auricolare, codice BDN di 14 caratteri, registrato entro 7 giorni. Identità individuale, per legge.' },
      { glyph: 'cow', time: 'Anni di lattazione', title: 'Vita produttiva', norm: 'disciplinare', trace: 'strong', note: 'Dieta a foraggi locali, divieto di insilati e di grassi in razione. Animale legato al territorio.' },
      { glyph: 'cow', time: 'Fine carriera', title: 'Riforma', norm: 'disciplinare', trace: 'strong', note: 'La vacca da riforma esce dalla vita produttiva. Da qui può lasciare il comprensorio.' },
      { glyph: null, time: 'Movimentazione', title: 'Uscita dalla stalla', norm: 'generale', trace: 'weak', note: 'Eventi tracciati in BDN (Modello 4), ma il claim DOP si indebolisce: nutrita a disciplinare fino a ieri, non per forza fino al macello.' },
      { glyph: null, time: 'Abbattimento', title: 'Macello', norm: 'generale', trace: 'weak', note: 'Evento notificato alla BDN, verifica ICA e bollo sanitario. Qui l’identità del singolo capo è ancora puntuale.' },
      { glyph: null, time: 'Fusione', title: 'Rendering', norm: 'generale', trace: 'lot', note: 'I tessuti adiposi di più animali confluiscono in lotti. L’identità individuale si dissolve. Sego di Categoria 3.' },
      { glyph: null, time: 'Partita', title: 'Lotto di sego', norm: 'generale', trace: 'lot', note: 'Il documento commerciale SOA traccia la partita, non più il singolo capo né l’allevamento DOP.' },
    ] as { glyph: 'cow' | 'calf' | null; time: string; title: string; norm: Norm; trace: Trace; note: string }[],
  },
  en: {
    normLabel: { cogente: 'Mandatory law', disciplinare: 'DOP specification', generale: 'General law' } as Record<Norm, string>,
    greyBracket: 'Grey area: from movement to lot, individual identity weakens and then dissolves',
    odeBracket: 'OdE re-links the origin: chain of custody · Digital Lipid Passport · AMSA',
    scrollHint: 'Scroll horizontally to follow the path →',
    legend: [
      { k: 'strong', t: 'Mandatory individual traceability (BDN herd register)' },
      { k: 'grey', t: 'Grey area: identity dissolving into the lot' },
      { k: 'ode', t: 'OdE intervention: the gap bridged' },
    ],
    stages: [
      { glyph: 'calf', time: 'Day 0', title: 'Birth', norm: 'cogente', trace: 'strong', note: 'The calf is born in a stable inside the DOP district.' },
      { glyph: null, time: 'Within 20 days', title: 'Identification', norm: 'cogente', trace: 'strong', note: 'Double ear tag, 14-character BDN code, registered within 7 days. Individual identity, by law.' },
      { glyph: 'cow', time: 'Years of lactation', title: 'Productive life', norm: 'disciplinare', trace: 'strong', note: 'Local-forage diet, no silage and no fats in the ration. The animal is bound to the territory.' },
      { glyph: 'cow', time: 'End of career', title: 'Culling', norm: 'disciplinare', trace: 'strong', note: 'The cull cow leaves productive life. From here it may leave the district.' },
      { glyph: null, time: 'Movement', title: 'Leaving the stable', norm: 'generale', trace: 'weak', note: 'Events logged in BDN (Model 4), but the DOP claim weakens: fed to specification until yesterday, not necessarily until slaughter.' },
      { glyph: null, time: 'Slaughter', title: 'Abattoir', norm: 'generale', trace: 'weak', note: 'Event notified to BDN, food-chain info and health stamp checked. The single animal’s identity is still precise here.' },
      { glyph: null, time: 'Rendering', title: 'Rendering', norm: 'generale', trace: 'lot', note: 'Adipose tissue from many animals merges into lots. Individual identity dissolves. Category 3 tallow.' },
      { glyph: null, time: 'Batch', title: 'Tallow lot', norm: 'generale', trace: 'lot', note: 'The ABP commercial document traces the lot, no longer the single animal or the DOP farm.' },
    ] as { glyph: 'cow' | 'calf' | null; time: string; title: string; norm: Norm; trace: Trace; note: string }[],
  },
};

const c = content[lang];
const n = c.stages.length;
---
<figure class="flow" role="group" aria-label={c.greyBracket}>
  <div class="flow-scroll">
    <div class="flow-grid" style={`--cols:${n}`}>

      {/* Row 1 — stage cards */}
      {c.stages.map((s, i) => (
        <article class:list={['stage', `t-${s.trace}`]} style={`grid-column:${i + 1}`}>
          <div class="stage-top">
            {s.glyph
              ? <CowGlyph variant={s.glyph} size={34} class="stage-glyph" />
              : <span class="stage-dot" aria-hidden="true"></span>}
            <span class="stage-time">{s.time}</span>
          </div>
          <h3 class="stage-title">{s.title}</h3>
          <span class:list={['stage-norm', `norm-${s.norm}`]}>{c.normLabel[s.norm]}</span>
          <p class="stage-note">{s.note}</p>
        </article>
      ))}

      {/* Row 2 — traceability strength ribbon */}
      {c.stages.map((s, i) => (
        <span class:list={['ribbon', `t-${s.trace}`]} style={`grid-column:${i + 1}`} aria-hidden="true"></span>
      ))}

      {/* Row 3 — grey-area bracket (stages 5-8) */}
      <div class="bracket grey" style={`grid-column:5 / ${n + 1}`}>
        <span>{c.greyBracket}</span>
      </div>

      {/* Row 4 — OdE bridge (spans the grey area) */}
      <div class="bracket ode" style={`grid-column:5 / ${n + 1}`}>
        <span>{c.odeBracket}</span>
      </div>

    </div>
  </div>

  <p class="scroll-hint">{c.scrollHint}</p>

  <ul class="legend">
    {c.legend.map((l) => (
      <li class:list={['leg', `leg-${l.k}`]}><span class="leg-swatch" aria-hidden="true"></span>{l.t}</li>
    ))}
  </ul>
</figure>

<style>
  .flow { margin: 1.5rem 0 0; }
  .flow-scroll { overflow-x: auto; padding-bottom: 0.5rem; -webkit-overflow-scrolling: touch; }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(150px, 1fr));
    grid-template-rows: auto auto auto auto;
    gap: 0.55rem;
    min-width: 1040px;
    align-items: stretch;
  }

  /* ── stage cards ── */
  .stage {
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--panel);
    border: 1px solid var(--rule);
    border-radius: var(--ode-radius);
    padding: 0.7rem 0.75rem 0.8rem;
  }
  .stage.t-lot { background: rgba(28, 38, 32, 0.05); }
  .stage-top { display: flex; align-items: center; gap: 0.45rem; min-height: 34px; }
  .stage-glyph { color: var(--accent); flex: none; }
  .stage.t-lot .stage-glyph, .stage.t-weak .stage-glyph { color: var(--muted); }
  .stage-dot {
    width: 10px; height: 10px; border-radius: 999px; flex: none;
    background: var(--bg); border: 2px solid var(--green-border);
  }
  .stage.t-weak .stage-dot { border-color: var(--muted); }
  .stage.t-lot .stage-dot { border-color: var(--muted); border-style: dashed; }
  .stage-time {
    font-family: var(--ode-font-mono); font-size: 0.64rem; letter-spacing: 0.03em;
    text-transform: uppercase; color: var(--muted);
  }
  .stage-title { font-size: 0.98rem; font-weight: 500; color: var(--ink); margin: 0; }
  .stage-norm {
    align-self: flex-start;
    font-family: var(--ode-font-mono); font-size: 0.58rem; font-weight: 500;
    letter-spacing: 0.03em; text-transform: uppercase;
    padding: 0.1em 0.45em; border-radius: 3px;
  }
  .norm-cogente { background: var(--green-soft); color: var(--accent); }
  .norm-disciplinare { background: #ece9fb; color: var(--lav-ink); }
  .norm-generale { background: rgba(28, 38, 32, 0.08); color: var(--muted); }
  .stage-note { font-size: 0.78rem; line-height: 1.45; color: var(--body); margin: 0; }

  /* ── traceability ribbon ── */
  .ribbon { grid-row: 2; height: 12px; border-radius: 999px; }
  .ribbon.t-strong { background: var(--green-border); }
  .ribbon.t-weak {
    background:
      repeating-linear-gradient(45deg, rgba(28,38,32,0.28) 0 5px, rgba(28,38,32,0.08) 5px 10px);
  }
  .ribbon.t-lot {
    background:
      repeating-linear-gradient(45deg, rgba(28,38,32,0.5) 0 5px, rgba(28,38,32,0.16) 5px 10px);
  }

  /* ── brackets ── */
  .bracket {
    border-radius: var(--ode-radius-sm);
    padding: 0.45rem 0.7rem;
    font-size: 0.76rem;
    line-height: 1.4;
    text-align: center;
  }
  .bracket.grey {
    grid-row: 3;
    background: rgba(28, 38, 32, 0.06);
    border: 1px dashed var(--muted);
    color: var(--body);
  }
  .bracket.ode {
    grid-row: 4;
    background: var(--accent);
    color: #fff;
    font-weight: 500;
    position: relative;
  }
  .bracket.ode::before {
    content: '';
    position: absolute; top: -7px; left: 50%; transform: translateX(-50%);
    border-left: 7px solid transparent; border-right: 7px solid transparent;
    border-bottom: 7px solid var(--accent);
  }

  /* ── hint + legend ── */
  .scroll-hint {
    display: none;
    font-family: var(--ode-font-mono); font-size: 0.7rem; color: var(--muted);
    margin: 0.4rem 0 0;
  }
  .legend {
    list-style: none; margin: 1.1rem 0 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem 1.4rem;
  }
  .leg { display: flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; color: var(--body); }
  .leg-swatch { width: 1.4rem; height: 0.65rem; border-radius: 999px; flex: none; }
  .leg-strong .leg-swatch { background: var(--green-border); }
  .leg-grey .leg-swatch {
    background: repeating-linear-gradient(45deg, rgba(28,38,32,0.5) 0 4px, rgba(28,38,32,0.16) 4px 8px);
  }
  .leg-ode .leg-swatch { background: var(--accent); border-radius: var(--ode-radius-sm); }

  @media (max-width: 760px) {
    .scroll-hint { display: block; }
  }
</style>
