---
// Placeholder body for a content section not yet built (Fase 3).
// Visible scaffolding marker — replaced by real content + brand styling.
interface Props {
  n: string;
  title: string;
  summary: string;
  /** Bullet list of what this section will contain, from PLAN.md. */
  willContain: string[];
  lang: 'it' | 'en';
}
const { n, title, summary, willContain, lang } = Astro.props;
const heading = lang === 'it' ? 'Conterrà' : 'Will contain';
const note = lang === 'it'
  ? 'Sezione in costruzione (scaffolding). I contenuti, le visualizzazioni e lo stile di marca arrivano nella Fase 3.'
  : 'Section under construction (scaffolding). Content, data visualisations and brand styling land in Phase 3.';
---
<section class="stub">
  <p class="stub-n">{n}</p>
  <h1>{title}</h1>
  <p class="stub-summary">{summary}</p>

  <div class="stub-note">
    <strong>{heading}</strong>
    <ul>
      {willContain.map((item) => <li>{item}</li>)}
    </ul>
    <p class="stub-flag">{note}</p>
  </div>
</section>

<style>
  .stub { max-width: 44rem; }
  .stub-n { font-family: var(--ode-font-mono); font-size: 0.8rem; color: var(--ode-muted); margin: 0 0 0.5rem; }
  .stub h1 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
  .stub-summary { font-size: 1.05rem; line-height: 1.6; margin: 1rem 0 2rem; color: var(--ode-body); }
  .stub-note {
    background: var(--ode-surface-alt);
    border: 1px dashed var(--ode-rule);
    border-radius: var(--ode-radius);
    padding: 1.25rem 1.5rem;
  }
  .stub-note ul { margin: 0.5rem 0 1rem; padding-left: 1.1rem; line-height: 1.7; }
  .stub-flag { font-size: 0.82rem; color: var(--ode-muted); margin: 0; font-style: italic; }
</style>
