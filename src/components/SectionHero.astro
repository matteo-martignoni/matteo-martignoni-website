---
// SectionHero — top of each section page (Think, Make, Circle, Visit)
// Number + section name + brief tagline + intro paragraph

interface Props {
  number: string;
  title: string;
  tagline: string;
  intro: string;
  quote?: string;
  quoteAuthor?: string;
}

const { number, title, tagline, intro, quote, quoteAuthor } = Astro.props;
---

<section class="max-w-3xl py-8 md:py-12">

  <div class="flex items-baseline gap-4 mb-8">
    <span class="text-xs uppercase tracking-widest text-terracotta-900 tabular-nums">
      {number}
    </span>
    <span class="text-xs uppercase tracking-widest text-ink-500">
      {tagline}
    </span>
  </div>

  <h1 class="text-3xl md:text-4xl font-medium text-ink-900 leading-tight mb-8">
    {title}
  </h1>

  <div class="w-10 h-px bg-sage-100 mb-8" aria-hidden="true"></div>

  <p class="text-ink-700 leading-relaxed">
    {intro}
  </p>

  {quote && (
    <figure class="mt-8 md:mt-10">
      <blockquote>
        <p
          class="italic text-terracotta-700 text-lg md:text-xl leading-relaxed"
          style="font-family: var(--font-serif, Georgia, serif);"
        >
          {quote}
        </p>
      </blockquote>
      {quoteAuthor && (
        <figcaption class="mt-3 text-xs uppercase tracking-widest text-ink-500">
          {quoteAuthor}
        </figcaption>
      )}
    </figure>
  )}

</section>
