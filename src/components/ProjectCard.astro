---
// ProjectCard — single project row with expandable detail
// Collapsed: marker + number + title + location + years + toggle
// Expanded: metadata grid + sage divider + narrative text (slot)

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  number: string;
  title: string;
  role: string;
  location: string;
  years: string;
  sector: string;
  founded?: boolean;
  meta?: MetaItem[];
  isFirst?: boolean;
  roleLabel?: string;
  sectorLabel?: string;
}

const {
  number,
  title,
  role,
  location,
  years,
  sector,
  founded = false,
  meta = [],
  isFirst = false,
  roleLabel = 'Role',
  sectorLabel = 'Sector',
} = Astro.props;
---

<details
  class="project group border-t border-warm-200"
  open={isFirst}
>
  <summary class="list-none cursor-pointer py-5 md:py-6 flex items-center gap-3 md:gap-4 hover:bg-sage-100/10 px-4 -mx-4 transition-colors duration-200">

    <!-- Founded marker — takes space even when not shown, keeps alignment -->
    <span
      class:list={[
        "w-1.5 h-1.5 rounded-full shrink-0",
        founded ? "bg-terracotta-500" : "invisible"
      ]}
      aria-hidden="true"
    ></span>

    <!-- Number -->
    <span class:list={[
      "text-xs uppercase tracking-wider tabular-nums shrink-0 w-5",
      founded ? "text-terracotta-900" : "text-ink-500/50 group-hover:text-terracotta-900 transition-colors duration-200"
    ]}>
      {number}
    </span>

    <!-- Title -->
    <h3 class="flex-1 text-base md:text-lg font-medium text-ink-900 leading-tight">
      {title}
    </h3>

    <!-- Location — hidden on mobile -->
    <span class="hidden md:inline text-xs uppercase tracking-wider text-ink-500/50 shrink-0 tabular-nums">
      {location}
    </span>

    <!-- Years -->
    <span class="text-xs uppercase tracking-wider text-ink-500/50 shrink-0 tabular-nums">
      {years}
    </span>

    <!-- Toggle icon -->
    <span
      class="text-xs text-terracotta-900 shrink-0 transition-transform duration-300 group-[&[open]]:rotate-45 ml-1"
      aria-hidden="true"
    >+</span>

  </summary>

  <!-- Expanded content -->
  <div class="pb-8 md:pb-10 pl-8 md:pl-10 pr-4 max-w-2xl">

    <!-- Metadata grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4 mb-8">

      <div>
        <p class="text-xs uppercase tracking-widest text-ink-500/60 mb-1">{roleLabel}</p>
        <p class="text-sm text-ink-700 leading-relaxed">{role}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-widest text-ink-500/60 mb-1">{sectorLabel}</p>
        <p class="text-sm text-ink-700 leading-relaxed">{sector}</p>
      </div>

      {meta.map(item => (
        <div>
          <p class="text-xs uppercase tracking-widest text-ink-500/60 mb-1">{item.label}</p>
          <p class="text-sm text-ink-700 leading-relaxed">{item.value}</p>
        </div>
      ))}

    </div>

    <!-- Sage divider -->
    <div class="w-8 h-px bg-sage-100 mb-6" aria-hidden="true"></div>

    <!-- Narrative text from slot -->
    <div class="project-body">
      <slot />
    </div>

  </div>
</details>

<style>
  /* Hide native details marker */
  details summary::-webkit-details-marker { display: none; }
  details summary::marker { display: none; }

  /* Narrative prose styling */
  .project-body :global(p) {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--color-ink-700, #3D3D3A);
    margin-bottom: 1rem;
  }
  .project-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>

<script>
  // Single-open accordion: opening one project closes the others
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('details.project');
    cards.forEach(detail => {
      detail.addEventListener('toggle', (event) => {
        const target = event.target as HTMLDetailsElement;
        if (target.open) {
          cards.forEach(other => {
            if (other !== target && (other as HTMLDetailsElement).open) {
              (other as HTMLDetailsElement).open = false;
            }
          });
        }
      });
    });
  });
</script>
