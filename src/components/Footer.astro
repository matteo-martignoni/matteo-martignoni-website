---
interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;

const copy = {
  en: {
    rights: 'All rights reserved.',
    linkedin: 'LinkedIn',
    vcard: 'vCard',
    cv: 'CV',
  },
  it: {
    rights: 'Tutti i diritti riservati.',
    linkedin: 'LinkedIn',
    vcard: 'vCard',
    cv: 'CV',
  },
};

const t = copy[lang];
const year = new Date().getFullYear();

// CV download — language-aware (EN / IT)
const cvHref = lang === 'it'
  ? '/cv/Matteo-Martignoni-CV-IT.pdf'
  : '/cv/Matteo-Martignoni-CV-EN.pdf';
---

<footer class="px-8 md:px-12 py-12 md:py-16 mt-16 border-t border-warm-200">

  <div class="max-w-3xl">

    <!-- Single line: MM mark + copyright + links -->
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">

      <svg
        width="29" height="18"
        viewBox="0 0 64 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        class="shrink-0"
      >
        <line x1="2" y1="38" x2="2" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="7" y1="38" x2="7" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="28" y1="38" x2="28" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="33" y1="38" x2="33" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="57" y1="38" x2="57" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="62" y1="38" x2="62" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="7" y1="2" x2="17" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="28" y1="2" x2="17" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="33" y1="2" x2="45" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
        <line x1="57" y1="2" x2="45" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      </svg>

      <span class="text-xs text-ink-500">
        &copy; {year} Matteo Martignoni. {t.rights}
      </span>

      <a
        href="https://www.linkedin.com/in/matteomartignoni/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-ink-500 hover:text-terracotta-900 transition-colors duration-200"
      >
        {t.linkedin}
      </a>

      <a
        href="/vcard.vcf"
        download
        class="text-xs text-ink-500 hover:text-terracotta-900 transition-colors duration-200"
      >
        {t.vcard}
      </a>

      <a
        href={cvHref}
        download
        class="text-xs text-ink-500 hover:text-terracotta-900 transition-colors duration-200"
      >
        {t.cv}
      </a>

    </div>

  </div>

</footer>
