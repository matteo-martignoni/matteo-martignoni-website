---
// CompetencyIcon — "filo unico" line icon for a competency row.
//
// One inline SVG per competency, selected by `number` (01–06). The markup is
// the canonical source from "Sito MM/Icone/icons.html".
//
// MUST be inlined in the DOM (not <img>) so currentColor and the CSS
// animations work. Animation styles + reduced-motion live in styles/icons.css.
//
// The icon is decorative — the competency title sits next to it — so it is
// aria-hidden. Animation is one-shot on entering the viewport (see script);
// without JS the SVG stays in its readable final state.
import '../styles/icons.css';

interface Props {
  number: string;
}
const { number } = Astro.props;
---
{number === '01' && (
  <svg class="icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M6 39c11-2 25-2 36 0"/>
    <path d="M24 39V15c4 0 7 2 8.4 4.2-2.2 2-5 3-8.4 3"/>
    <g class="flag-l"><path d="M13 39V23c3 0 5.2 1.4 6.2 3-1.6 1.5-3.7 2.2-6.2 2.2"/></g>
    <g class="flag-r"><path d="M35 39V23c3 0 5.2 1.4 6.2 3-1.6 1.5-3.7 2.2-6.2 2.2"/></g>
  </svg>
)}
{number === '02' && (
  <svg class="icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M14 41c-2.6-7.5-2.6-16 0-23.5 7.5-2.6 16-2.6 23.5 0 2.6 7.5 2.6 16 0 23.5-7.5 2.6-16 2.6-23.5 0-2.4-7-2.5-14.5-.4-21.8"/>
    <g class="box-l"><path d="M3 10c2.6-1 5.6-1 8 0 1 2.6 1 5.6 0 8-2.6 1-5.6 1-8 0-.9-2.4-1-5 .3-7.6"/></g>
    <g class="box-r"><path d="M33 10c2.6-1 5.6-1 8 0 1 2.6 1 5.6 0 8-2.6 1-5.6 1-8 0-.9-2.4-1-5 .3-7.6"/></g>
  </svg>
)}
{number === '03' && (
  <svg class="icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M11 18c-4 2.5-4 9.5 0 12 2.5 1.6 4.8 1.6 7 .8"/>
    <path d="M11 19.5l.2 4M14 19l.2 4.5M17 19.6l.2 3.8"/>
    <path d="M37 18c4 2.5 4 9.5 0 12-2.5 1.6-4.8 1.6-7 .8"/>
    <path d="M37 19.5l-.2 4M34 19l-.2 4.5M31 19.6l-.2 3.8"/>
    <circle class="pass" cx="24" cy="25" r="4.4"/>
  </svg>
)}
{number === '04' && (
  <svg class="icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M12 41V18c0-4 14-8 24-2.5"/>
    <path d="M36 15.5V41"/>
    <path d="M7 41h34"/>
    <path class="door" d="M14 19l20 1.5v19L14 41c-2.2-7.3-2.2-14.7 0-22z"/>
  </svg>
)}
{number === '05' && (
  <svg class="icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <path d="M1 37h4"/>
    <path d="M5 37c7 0 9-15 19-15s12 15 19 15"/>
    <path d="M43 37h4"/>
    <g class="walker" transform="translate(39,33)">
      <circle cx="0" cy="-8" r="2.2"/>
      <path d="M0 -5.8v6.4M0 -2.4l-3.4 4.6M0 -2.4l3.4 4.6"/>
    </g>
  </svg>
)}
{number === '06' && (
  <svg class="icon" viewBox="0 0 48 48" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    <defs><path id="ico-star" d="M0 -4 0.94 -1.29 3.8 -1.24 1.52 0.49 2.35 3.24 0 1.6 -2.35 3.24 -1.52 0.49 -3.8 -1.24 -0.94 -1.29Z"/></defs>
    <use href="#ico-star" transform="translate(6,24)"/>
    <use href="#ico-star" transform="translate(15,24)"/>
    <use href="#ico-star" class="star-3" transform="translate(24,24)"/>
    <use href="#ico-star" class="star-4" transform="translate(33,24)"/>
    <use href="#ico-star" class="star-5" transform="translate(42,24)"/>
  </svg>
)}

<script>
  // One-shot reveal: mark every .icon, then play its animation once it scrolls
  // into view. Without JS the icon stays in its final (readable) state.
  // Reduced-motion is handled in CSS. Runs once (Astro bundles module scripts).
  const icons = document.querySelectorAll<SVGElement>('.icon');
  icons.forEach((el) => el.classList.add('animate'));

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('play');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.5 }
  );
  icons.forEach((el) => io.observe(el));
</script>
