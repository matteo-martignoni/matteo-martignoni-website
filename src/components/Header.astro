---
import Navigation from './Navigation.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;
const homeUrl = lang === 'it' ? '/it/' : '/';
---

<header class="px-8 md:px-12 py-6 flex items-center justify-between">

  <!-- Brand: MM mark + site name -->
  <a href={homeUrl} class="flex items-center gap-3 group" aria-label="Matteo Martignoni — home">

    <!-- MM monogram mark in sage, no circle -->
    <svg
      width="35" height="22"
      viewBox="0 0 64 40"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      class="shrink-0 transition-opacity duration-200 group-hover:opacity-70"
    >
      <line x1="2" y1="38" x2="2" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="7" y1="38" x2="7" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="28" y1="38" x2="28" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="33" y1="38" x2="33" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="57" y1="38" x2="57" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="62" y1="38" x2="62" y2="2" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="7" y1="2" x2="17" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="28" y1="2" x2="17" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="33" y1="2" x2="45" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
      <line x1="57" y1="2" x2="45" y2="22" stroke="#A8D4BC" stroke-width="2" stroke-linecap="round"/>
    </svg>

    <!-- Site name -->
    <span class="text-sm font-medium text-ink-900 tracking-wide transition-opacity duration-200 group-hover:opacity-70">
      Matteo Martignoni
    </span>

  </a>

  <!-- Navigation + language switcher -->
  <div class="flex items-center gap-6 md:gap-8">
    <Navigation lang={lang} />
    <LanguageSwitcher lang={lang} />
  </div>

</header>
