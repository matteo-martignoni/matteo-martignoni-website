---
// MaestroCard — a single mentor with expandable italic quote
// Collapsed: name + role
// Expanded: vertical sage line + italic serif quote + optional portrait + optional project link
// First mentor is open by default
interface Props {
  name: string;
  role: string;
  portrait?: string;
  projectHref?: string;
  projectLabel?: string;
  linkPrefix?: string;
  isFirst?: boolean;
  /** Enlarge the portrait by ~50% on mobile only (desktop unchanged) */
  portraitMobileBoost?: boolean;
}
const {
  name,
  role,
  portrait,
  projectHref,
  projectLabel,
  linkPrefix = 'A project we worked on',
  isFirst = false,
  portraitMobileBoost = false,
} = Astro.props;
---
<details
  class="maestro group border-t border-warm-200 py-10 md:py-12"
  open={isFirst}
>
  <summary class="list-none cursor-pointer flex items-start justify-between gap-6 hover:opacity-80 transition-opacity duration-200">
    <div>
      <h3 class="text-xl md:text-2xl font-medium text-ink-900 leading-tight">
        {name}
      </h3>
      <p class="text-sm text-ink-500 mt-1.5">
        {role}
      </p>
    </div>
    <span
      class="text-xs text-terracotta-900 shrink-0 mt-1 transition-transform duration-500 group-[&[open]]:rotate-45"
      aria-hidden="true"
    >+</span>
  </summary>

  <!-- Expanded: quote left + portrait right -->
  <div class="mt-8 flex flex-col-reverse md:flex-row md:items-start md:gap-12">

    <!-- Left: sage line + quote + link -->
    <div class="flex-1 pl-5 border-l-2 border-sage-100 mt-8 md:mt-0">
      <div class="maestro-body">
        <slot />
      </div>
      {projectHref && projectLabel && (
        <a
          href={projectHref}
          class="inline-flex items-center gap-2 mt-6 text-xs uppercase tracking-wider text-terracotta-900 hover:text-terracotta-700 transition-colors duration-200"
        >
          <span aria-hidden="true">→</span>
          <span>{linkPrefix}: {projectLabel}</span>
        </a>
      )}
    </div>

    <!-- Right: illustrated portrait (optional) -->
    {portrait && (
      <div class:list={[portraitMobileBoost ? "w-[13.5rem]" : "w-36", "md:w-44 shrink-0 self-start"]}>
        <img
          src={portrait}
          alt=""
          aria-hidden="true"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
    )}

  </div>
</details>

<style>
  details summary::-webkit-details-marker { display: none; }
  details summary::marker { display: none; }
  /* Quotation — markdown blockquote → italic, terracotta, serif */
  .maestro-body :global(blockquote) {
    margin: 0 0 1.25rem;
    padding: 0;
    border: 0;
  }
  .maestro-body :global(blockquote p) {
    font-family: var(--font-serif, Georgia, serif);
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-terracotta-700, #A55A3D);
    margin: 0 0 0.6rem;
  }
  .maestro-body :global(blockquote p:last-child) { margin-bottom: 0; }

  /* Commentary prose — regular ink */
  .maestro-body :global(p) {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-700, #3D3D3A);
    margin: 0 0 0.9rem;
  }
  .maestro-body :global(p:last-child) { margin-bottom: 0; }
</style>

<script>
  // Single-open accordion: opening one maestro closes the others
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('details.maestro');
    cards.forEach(detail => {
      detail.addEventListener('toggle', (event) => {
        const target = event.target as HTMLDetailsElement;
        if (!target.open) return;
        // Closing the others removes height above this card; without the
        // re-anchor below the opened card would slide off the top of the
        // screen (mobile). Anchor its top edge to the top of the viewport.
        cards.forEach(other => {
          if (other !== target && (other as HTMLDetailsElement).open) {
            (other as HTMLDetailsElement).open = false;
          }
        });
        requestAnimationFrame(() => {
          const top = target.getBoundingClientRect().top + window.scrollY - 12;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });
    });
  });
</script>
