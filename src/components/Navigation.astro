---
interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;

const path = Astro.url.pathname;

// Navigation items per language
const nav = lang === 'en'
  ? [
      { label: 'Think',  href: '/think'  },
      { label: 'Make',   href: '/make'   },
      { label: 'Circle', href: '/circle' },
      { label: 'Visit',  href: '/visit'  },
    ]
  : [
      { label: 'Pensiero',  href: '/it/pensiero'  },
      { label: 'Manualità', href: '/it/manualita' },
      { label: 'Maestri',   href: '/it/maestri'   },
      { label: 'Bottega',   href: '/it/bottega'   },
    ];

// A route is active if the current path starts with its href
// (handles sub-paths and trailing slashes)
function isActive(href: string): boolean {
  return path === href || path === href + '/' || path.startsWith(href + '/');
}
---

<nav aria-label="Main navigation">
  <ul class="flex items-center gap-6 md:gap-8 list-none m-0 p-0">
    {nav.map(item => (
      <li>
        <a
          href={item.href}
          class:list={[
            "text-xs uppercase tracking-wider transition-colors duration-200",
            isActive(item.href)
              ? "text-terracotta-900 font-medium"
              : "text-ink-500 font-normal hover:text-ink-900"
          ]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
