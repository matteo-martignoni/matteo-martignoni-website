---
// CompetencyAccordion — single competency item with expandable detail
// First competency in the list is open by default; clicking another closes the open one
// Uses native <details>/<summary> for accessibility, with custom styling

interface Props {
  number: string;
  title: string;
  description: string;
  examples?: string[];
  isFirst?: boolean;
}

const { number, title, description, examples = [], isFirst = false } = Astro.props;
---

<details
  class="competency group border-t border-warm-200 [&[open]]:bg-sage-100/8 transition-colors duration-300"
  open={isFirst}
>
  <summary class="cursor-pointer list-none py-6 md:py-7 flex items-baseline gap-5 md:gap-6 transition-colors duration-200 hover:bg-sage-100/15 px-4 -mx-4">

    <span class="text-xs uppercase tracking-widest text-terracotta-900 tabular-nums shrink-0 w-6">
      {number}
    </span>

    <h3 class="flex-1 text-base md:text-lg font-medium text-ink-900">
      {title}
    </h3>

    <span
      class="text-xs uppercase tracking-widest text-terracotta-900 shrink-0 transition-transform duration-300 group-[&[open]]:rotate-45"
      aria-hidden="true"
    >
      +
    </span>
  </summary>

  <div class="pb-8 md:pb-10 pl-12 md:pl-14 pr-4 max-w-2xl">
    <p class="text-ink-700 leading-relaxed mb-6">
      {description}
    </p>

    {examples.length > 0 && (
      <div>
        <div class="w-8 h-px bg-sage-100 mb-5" aria-hidden="true"></div>
        <ul class="space-y-3">
          {examples.map(example => (
            <li class="text-sm text-ink-500 leading-relaxed">
              {example}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</details>

<style>
  /* Hide native details marker across browsers */
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary::marker {
    display: none;
  }
</style>

<script>
  // Single-open accordion behavior:
  // When one competency opens, close all the others in the same group
  document.addEventListener('DOMContentLoaded', () => {
    const competencies = document.querySelectorAll('details.competency');
    competencies.forEach(detail => {
      detail.addEventListener('toggle', (event) => {
        const target = event.target as HTMLDetailsElement;
        if (target.open) {
          competencies.forEach(other => {
            if (other !== target && (other as HTMLDetailsElement).open) {
              (other as HTMLDetailsElement).open = false;
            }
          });
        }
      });
    });
  });
</script>
