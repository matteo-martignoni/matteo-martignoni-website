---
// Homepage hero — shared by EN (/) and IT (/it/).
//
// Composition (approved direction "2A"): title on the left; on the right a
// single continuous-line scene of head + hands. The portrait (mind) sits in a
// sage disk; the hands (making) rise from below over a terracotta disk —
// "hand & mind" fused into one image.
//
// Layout is percentage-based inside a fixed-aspect stage so it scales cleanly.
// Desktop: two columns. Mobile: title on top, composition below.

interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;

const copy = {
  en: {
    h1: 'Hand & mind.',
    sub: 'Workshop of brands.',
    intro:
      'Twenty-five years building and repositioning brands across fashion, beauty, culture, and technology. Italy-based, internationally active.',
    portraitAlt: 'Continuous-line portrait of Matteo Martignoni',
  },
  it: {
    h1: 'Testa e mani.',
    sub: 'La bottega dei marchi.',
    intro:
      'Venticinque anni a costruire e riposizionare marchi nella moda, bellezza, cultura e tecnologia. Basato in Italia, attivo a livello internazionale.',
    portraitAlt: 'Ritratto a tratto continuo di Matteo Martignoni',
  },
};

const t = copy[lang];
---

<section class="home-hero">

  <div class="home-copy">
    <h1>{t.h1}</h1>
    <p class="sub">{t.sub}</p>
    <p class="intro">{t.intro}</p>
  </div>

  <div class="home-stage">
    <div class="disk sage" aria-hidden="true"></div>
    <img
      class="portrait"
      src="/images/home/portrait.png"
      alt={t.portraitAlt}
      width="1122"
      height="1402"
      fetchpriority="high"
    />
    <div class="disk terra" aria-hidden="true"></div>
    <img
      class="hands"
      src="/images/home/hands.png"
      alt=""
      aria-hidden="true"
      width="1086"
      height="1448"
    />
  </div>

</section>

<style>
  /* Mobile-first: title on top, composition below */
  .home-hero {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    max-width: 100%;
    overflow-x: clip; /* the composition never forces horizontal scroll */
  }

  .home-copy { order: 1; }
  .home-stage { order: 2; }

  .home-copy h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-ink-900);
  }

  .home-copy .sub {
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--color-ink-500);
    margin-top: 0.6rem;
    margin-bottom: 1.8rem;
  }

  .home-copy .intro {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-700);
    max-width: 100%;
  }

  /* Stage: fixed aspect so the absolutely-positioned figures scale together */
  .home-stage {
    position: relative;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    aspect-ratio: 4 / 5;
  }

  .home-stage .portrait {
    position: absolute;
    z-index: 1;
    height: 70%;
    width: auto;
    left: 50%;
    top: -2%;
    transform: translateX(-50%);
  }

  .home-stage .hands {
    position: absolute;
    z-index: 1;
    height: 46%;
    width: auto;
    left: 50%;
    bottom: -4%;
    transform: translateX(-50%);
  }

  .home-stage .disk {
    position: absolute;
    z-index: 0;
    border-radius: 9999px;
    aspect-ratio: 1;
  }

  .home-stage .disk.sage {
    width: 77%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    background: var(--color-sage-100);
    opacity: 0.85;
  }

  .home-stage .disk.terra {
    width: 46%;
    left: 50%;
    bottom: -2%;
    transform: translateX(-48%);
    background: var(--color-terracotta-500);
    opacity: 0.55;
  }

  /* Desktop: title left, composition right */
  @media (min-width: 768px) {
    .home-hero {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
      min-height: 72vh;
    }
    .home-copy { flex: 1 1 45%; }
    .home-copy .intro { max-width: 30rem; }
    .home-stage { flex: 1 1 55%; max-width: 520px; }
  }
</style>
