---
// LanguageSwitcher — EN / IT toggle in top right
// Active language in muted ink, target language in terracotta accent
// Maps section paths bilingually: /think ↔ /it/pensiero, etc.

import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath = '/' } = Astro.props;

// Bidirectional section route mapping
// EN slug → IT slug (and vice versa via reverse lookup)
const sectionMap: Record<string, string> = {
  think: 'pensiero',
  make: 'manualita',
  circle: 'maestri',
  visit: 'bottega',
};

const reverseSectionMap: Record<string, string> = Object.fromEntries(
  Object.entries(sectionMap).map(([en, it]) => [it, en])
);

// Compute the URL of the current page in the opposite language
function getAltUrl(): string {
  // Strip leading/trailing slashes for clean parsing
  const path = currentPath.replace(/^\/+|\/+$/g, '');

  if (lang === 'en') {
    // EN → IT
    if (!path) return '/it/'; // root home
    const itSlug = sectionMap[path];
    if (itSlug) return `/it/${itSlug}`;
    return '/it/'; // fallback to IT home if no mapping
  } else {
    // IT → EN
    // Path looks like "it" or "it/pensiero"
    const parts = path.split('/');
    if (parts.length <= 1) return '/'; // /it/ → /
    const itSlug = parts[1]; // e.g. "pensiero"
    const enSlug = reverseSectionMap[itSlug];
    if (enSlug) return `/${enSlug}`;
    return '/'; // fallback to EN home
  }
}

const altUrl = getAltUrl();
const altLabel = lang === 'en' ? 'IT' : 'EN';
const currentLabel = lang === 'en' ? 'EN' : 'IT';
---

<div class="flex items-center gap-1 text-xs tracking-wider">
  <span class="text-ink-500/60">{currentLabel}</span>
  <span class="text-ink-500/40">/</span>
  <a
    href={altUrl}
    class="text-terracotta-900 hover:text-terracotta-700 transition-colors duration-200"
    aria-label={`Switch to ${altLabel === 'IT' ? 'Italian' : 'English'}`}
  >
    {altLabel}
  </a>
</div>
